<!--pages/merchant/orders/orders.wxml-->
<view class="order-list-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <icon class="search-icon" type="search" size="20"></icon>
      <input 
        type="text" 
        placeholder="搜索订单号或用户昵称" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <text class="clear-btn" wx:if="{{searchKeyword}}" bindtap="clearSearch">×</text>
    </view>
  </view>

  <!-- 状态筛选Tab -->
  <view class="status-tabs">
    <view 
      class="tab-item {{activeTab === 'all' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="all"
    >
      全部
    </view>
    <view 
      class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="pending"
    >
      待发货
    </view>
    <view 
      class="tab-item {{activeTab === 'shipped' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="shipped"
    >
      已发货
    </view>
    <view 
      class="tab-item {{activeTab === 'completed' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="completed"
    >
      已完成
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view 
      class="order-card" 
      wx:for="{{orders}}" 
      wx:key="{{item.id}}"
      bindtap="goToOrderDetail" 
      data-id="{{item.id}}"
    >
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-info">
          <text class="order-id">订单号：{{item.order_no}}</text>
          <text class="order-time">{{item.created_at}}</text>
        </view>
        <view class="order-status {{getStatusClass(item.status)}}">
          {{getStatusText(item.status)}}
        </view>
      </view>

      <!-- 商品信息 -->
      <view class="order-products">
        <view 
          class="product-item" 
          wx:for="{{item.products}}" 
          wx:key="{{productItem.id}}"
          wx:for-item="productItem"
          wx:for-index="index"
        >
          <view class="product-info">
            <text class="product-name">{{productItem.name}}</text>
            <text class="product-quantity">x{{productItem.quantity}}</text>
          </view>
        </view>
        <view class="more-products" wx:if="{{item.products.length > 2}}">
          等{{item.products.length}}件
        </view>
      </view>

      <!-- 订单底部 -->
      <view class="order-footer">
        <view class="order-amount">
          实付：<text class="amount-value">¥{{item.amount}}</text>
        </view>
        <view class="order-actions">
          <button 
            class="action-btn secondary" 
            bindtap="goToOrderDetail" 
            data-id="{{item.id}}"
          >
            查看详情
          </button>
          <button 
            class="action-btn primary" 
            bindtap="handleShip" 
            data-id="{{item.id}}"
            wx:if="{{item.status === 1}}"
          >
            发货
          </button>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:else>上拉加载更多</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <image class="empty-icon" src="../../../assets/empty-order.png"></image>
    <text class="empty-text">暂无符合条件的订单</text>
    <button class="refresh-btn" bindtap="refreshOrders">刷新</button>
  </view>
</view>