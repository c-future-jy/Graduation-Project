<!--pages/merchant/order-detail/order-detail.wxml-->
<view class="order-detail-page">
  <!-- 订单基础信息 -->
  <view class="order-info-section">
    <view class="section-title">订单信息</view>
    <view class="info-item">
      <text class="info-label">订单号：</text>
      <text class="info-value">{{orderInfo.order_no}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">下单时间：</text>
      <text class="info-value">{{orderInfo.created_at}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">支付方式：</text>
      <text class="info-value">{{orderInfo.payment_method || '微信支付'}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">支付状态：</text>
      <text class="info-value {{orderInfo.payment_status === 1 ? 'paid' : 'unpaid'}}">
        {{orderInfo.payment_status === 1 ? '已支付' : '未支付'}}
      </text>
    </view>
    <view class="info-item" wx:if="{{orderInfo.remark}}">
      <text class="info-label">订单备注：</text>
      <text class="info-value">{{orderInfo.remark}}</text>
    </view>
    <view class="info-item" wx:else>
      <text class="info-label">订单备注：</text>
      <text class="info-value">无备注</text>
    </view>
  </view>

  <!-- 用户信息 -->
  <view class="user-info-section">
    <view class="section-title">用户信息</view>
    <view class="user-info">
      <view class="user-avatar">
        <image src="{{orderInfo.user_avatar || '../../../assets/default-avatar.png'}}" mode="aspectFill"></image>
      </view>
      <view class="user-details">
        <view class="user-name">{{orderInfo.user_nickname}}</view>
        <view class="user-phone">{{getMaskedPhone(orderInfo.user_phone)}}</view>
      </view>
    </view>
  </view>

  <!-- 商品清单 -->
  <view class="products-section">
    <view class="section-title">商品清单</view>
    <view class="product-list">
      <view 
        class="product-item" 
        wx:for="{{orderInfo.products}}" 
        wx:key="{{item.id}}"
        wx:for-item="productItem"
      >
        <view class="product-image">
          <image src="{{productItem.image || '../../../assets/default-product.png'}}" mode="aspectFill"></image>
        </view>
        <view class="product-info">
          <view class="product-name">{{productItem.name}}</view>
          <view class="product-spec" wx:if="{{productItem.spec}}">{{productItem.spec}}</view>
          <view class="product-price-info">
            <text class="product-price">¥{{productItem.price}}</text>
            <text class="product-quantity">x{{productItem.quantity}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 收货信息 -->
  <view class="address-section">
    <view class="section-title">收货信息</view>
    <view class="address-info">
      <view class="address-header">
        <text class="receiver-name">{{orderInfo.receiver_name}}</text>
        <text class="receiver-phone">{{getMaskedPhone(orderInfo.receiver_phone)}}</text>
      </view>
      <view class="receiver-address">{{orderInfo.receiver_address}}</view>
    </view>
  </view>

  <!-- 订单金额 -->
  <view class="amount-section">
    <view class="amount-item">
      <text class="amount-label">商品总价：</text>
      <text class="amount-value">¥{{orderInfo.product_amount}}</text>
    </view>
    <view class="amount-item">
      <text class="amount-label">运费：</text>
      <text class="amount-value">¥{{orderInfo.shipping_fee}}</text>
    </view>
    <view class="amount-item total">
      <text class="amount-label">实付金额：</text>
      <text class="amount-value total">¥{{orderInfo.amount}}</text>
    </view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="bottom-actions">
    <view class="order-status">{{getStatusText(orderInfo.status)}}</view>
    <view class="action-buttons">
      <button 
        class="action-btn secondary" 
        bindtap="goToOrderList"
      >
        返回列表
      </button>
      <button 
        class="action-btn primary" 
        bindtap="handleShip" 
        wx:if="{{orderInfo.status === 1}}"
      >
        发货
      </button>
      <button 
        class="action-btn primary" 
        bindtap="handleCancel" 
        wx:if="{{orderInfo.status === 1}}"
      >
        取消订单
      </button>
      <button 
        class="action-btn primary" 
        bindtap="viewFeedback" 
        wx:if="{{orderInfo.status === 3}}"
      >
        查看评价
      </button>
    </view>
  </view>
</view>