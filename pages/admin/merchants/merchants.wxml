<!-- pages/admin/merchants/merchants.wxml -->
<view class="merchants-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">商家管理</text>
  </view>

  <!-- 搜索和筛选 -->
  <view class="search-filter">
    <view class="search-box">
      <input 
        class="search-input" 
        placeholder="输入商家名称或店主搜索" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
      <button class="search-btn" bindtap="searchMerchants">搜索</button>
    </view>
    <view class="filter-box">
      <picker class="filter-picker" range="{{statusOptions}}" range-key="label" value="{{statusPickerIndex}}" bindchange="onStatusPickerChange">
        <view class="picker-text">
          状态：{{statusOptions[statusPickerIndex].label}}
        </view>
      </picker>
      <picker class="filter-picker" range="{{auditOptions}}" range-key="label" value="{{auditPickerIndex}}" bindchange="onAuditPickerChange">
        <view class="picker-text">
          审核状态：{{auditOptions[auditPickerIndex].label}}
        </view>
      </picker>
    </view>
  </view>

  <!-- 批量操作 -->
  <view class="batch-actions">
    <checkbox-group bindchange="selectAllMerchants">
      <label class="checkbox-label">
        <checkbox value="all" checked="{{merchants.length > 0 && selectedMerchants.length === merchants.length}}" />
        <text>全选</text>
      </label>
    </checkbox-group>
    <button class="batch-btn" bindtap="batchDisableMerchants">批量禁用</button>
    <button class="batch-btn" bindtap="batchEnableMerchants">批量启用</button>
  </view>

  <!-- 商家列表 -->
  <view class="merchants-table">
    <view class="table-header">
      <view class="table-col select-col">选择</view>
      <view class="table-col id-col">ID</view>
      <view class="table-col name-col">商家名称</view>
      <view class="table-col owner-col">店主</view>
      <view class="table-col phone-col">联系电话</view>
      <view class="table-col address-col">地址</view>
      <view class="table-col status-col">状态</view>
      <view class="table-col audit-col">审核状态</view>
      <view class="table-col action-col">操作</view>
    </view>
    <view class="table-body">
      <view wx:for="{{merchants}}" wx:key="id" class="table-row">
        <view class="table-col select-col">
          <checkbox-group bindchange="selectMerchant" data-id="{{item.id}}">
            <label class="checkbox-label">
              <checkbox value="{{item.id}}" checked="{{selectedMap[item.id]}}" />
            </label>
          </checkbox-group>
        </view>
        <view class="table-col id-col">{{item.id}}</view>
        <view class="table-col name-col">{{item.name}}</view>
        <view class="table-col owner-col">{{item.owner}}</view>
        <view class="table-col phone-col">{{item.phone}}</view>
        <view class="table-col address-col">{{item.address}}</view>
        <view class="table-col status-col">
          <text class="status-tag {{item.status === 1 ? 'open' : 'closed'}}">{{item.statusText}}</text>
        </view>
        <view class="table-col audit-col">
          <text class="audit-tag {{item.auditStatus === 1 ? 'pending' : item.auditStatus === 2 ? 'passed' : 'rejected'}}">{{item.auditStatusText}}</text>
        </view>
        <view class="table-col action-col">
          <button class="action-btn view" bindtap="viewMerchantDetail" data-id="{{item.id}}">查看</button>
          <button 
            class="action-btn {{item.status === 1 ? 'disable' : 'enable'}}" 
            bindtap="toggleMerchantStatus" 
            data-id="{{item.id}}" 
            data-status="{{item.status}}"
          >
            {{item.status === 1 ? '禁用' : '启用'}}
          </button>
          <button wx:if="{{item.auditStatus === 1}}" class="action-btn audit" bindtap="auditMerchant" data-id="{{item.id}}">审核</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{merchants.length === 0 && !loading}}" class="empty-state">
    <image class="empty-icon" src="/assets/images/kong.jpg" mode="aspectFit" />
    <text class="empty-text">未找到相关商家</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <!-- 分页信息 -->
  <view wx:if="{{merchants.length > 0}}" class="pagination">
    <text>共 {{total}} 条记录</text>
    <text wx:if="{{!hasMore}}" class="no-more">没有更多数据了</text>
  </view>

  <!-- 商家详情弹窗 -->
  <view wx:if="{{detailVisible}}" class="detail-mask" bindtap="closeMerchantDetail">
    <view class="detail-panel" bindtap="stopTap">
      <view class="detail-header">
        <text class="detail-title">商家详情</text>
        <text class="detail-close" bindtap="closeMerchantDetail">×</text>
      </view>

      <view wx:if="{{detailLoading}}" class="detail-loading">
        <text>加载中...</text>
      </view>

      <scroll-view wx:if="{{!detailLoading && detail}}" scroll-y class="detail-content">
        <view class="detail-section">
          <text class="section-title">商家基本信息</text>
          <view class="detail-row">
            <text class="detail-label">Logo</text>
            <view class="detail-value">
              <image class="detail-avatar" mode="aspectFill" src="{{detail.basic.logo || ''}}" wx:if="{{detail.basic.logo}}" />
              <view class="detail-avatar placeholder" wx:else></view>
            </view>
          </view>
          <view class="detail-row">
            <text class="detail-label">名称</text>
            <text class="detail-value">{{detail.basic.name || '-'}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">地址</text>
            <text class="detail-value">{{detail.basic.address || '-'}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">电话</text>
            <text class="detail-value">{{detail.basic.phone || '-'}}</text>
          </view>
        </view>

        <view class="detail-section">
          <text class="section-title">店主信息</text>
          <view class="detail-row">
            <text class="detail-label">用户ID</text>
            <text class="detail-value">{{detail.owner && detail.owner.id ? detail.owner.id : '-'}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">昵称</text>
            <text class="detail-value">{{detail.owner && detail.owner.nickname ? detail.owner.nickname : '-'}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">账号</text>
            <text class="detail-value">{{detail.owner && detail.owner.username ? detail.owner.username : '-'}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">手机号</text>
            <text class="detail-value">{{detail.owner && detail.owner.phone ? detail.owner.phone : '-'}}</text>
          </view>
        </view>

        <view class="detail-section">
          <text class="section-title">状态信息</text>
          <view class="detail-row">
            <text class="detail-label">营业状态</text>
            <text class="detail-value">{{detail.statusText}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">审核状态</text>
            <text class="detail-value">{{detail.auditStatusText}}</text>
          </view>
        </view>

        <view class="detail-section">
          <text class="section-title">商品列表及库存</text>
          <view wx:if="{{detail.products.length === 0}}" class="detail-row">
            <text class="detail-label">商品</text>
            <text class="detail-value">暂无</text>
          </view>
          <view wx:for="{{detail.products}}" wx:key="id" class="detail-row">
            <text class="detail-label">{{item.name}}</text>
            <text class="detail-value">库存 {{item.stock}}（{{item.statusText}}）</text>
          </view>
        </view>

        <view class="detail-section">
          <text class="section-title">订单统计</text>
          <view class="detail-row">
            <text class="detail-label">订单总数</text>
            <text class="detail-value">{{detail.stats.orderCount}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">处理中</text>
            <text class="detail-value">{{detail.stats.processingCount}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">已完成</text>
            <text class="detail-value">{{detail.stats.finishedCount}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">营业额</text>
            <text class="detail-value">{{detail.stats.totalRevenue}}</text>
          </view>
        </view>

        <view class="detail-section">
          <text class="section-title">用户评价反馈</text>
          <view class="detail-row">
            <text class="detail-label">平均评分</text>
            <text class="detail-value">{{detail.feedback.avgRating}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">评价数量</text>
            <text class="detail-value">{{detail.feedback.count}}</text>
          </view>
          <view wx:if="{{detail.feedback.list.length === 0}}" class="detail-row">
            <text class="detail-label">最近评价</text>
            <text class="detail-value">暂无</text>
          </view>
          <view wx:for="{{detail.feedback.list}}" wx:key="id" class="detail-row">
            <text class="detail-label">{{item.user_name || '用户'}}（{{item.rating || '-'}}星）</text>
            <text class="detail-value">{{item.content || '-'}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 审核弹窗 -->
  <view wx:if="{{auditVisible}}" class="audit-mask" bindtap="closeAudit">
    <view class="audit-panel" bindtap="stopTap">
      <view class="detail-header">
        <text class="detail-title">商家审核</text>
        <text class="detail-close" bindtap="closeAudit">×</text>
      </view>

      <view class="audit-body">
        <view class="audit-row">
          <text class="audit-label">商家</text>
          <text class="audit-value">{{auditTarget && auditTarget.name ? auditTarget.name : '-'}}</text>
        </view>
        <view class="audit-row">
          <text class="audit-label">驳回原因</text>
          <textarea class="audit-input" placeholder="驳回时必填" value="{{auditRemark}}" bindinput="onAuditRemarkInput" />
        </view>
      </view>

      <view class="audit-footer">
        <button class="action-btn disable" bindtap="submitAuditReject" disabled="{{auditSubmitting}}">驳回</button>
        <button class="action-btn enable" bindtap="submitAuditApprove" disabled="{{auditSubmitting}}">通过</button>
      </view>
    </view>
  </view>
</view>