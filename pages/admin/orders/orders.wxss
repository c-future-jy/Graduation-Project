.orders-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.search-filter {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.search-btn {
  background-color: #1890ff;
  color: white;
  border: none;
  padding: 0 32rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.filter-box {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.filter-picker {
  flex: 1;
  min-width: 200rpx;
  height: 60rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.batch-actions {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.checkbox-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.batch-btn {
  background-color: #f0f0f0;
  color: #333;
  border: none;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.supervise-bar {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #666;
}

.status-counts {
  background-color: white;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
  font-size: 22rpx;
  color: #666;
}

.count-item {
  padding: 6rpx 10rpx;
  background: #fafafa;
  border-radius: 8rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  padding: 18rpx;
  display: flex;
  gap: 14rpx;
}

.card-check {
  width: 64rpx;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding-top: 6rpx;
}

.card-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.order-no {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta {
  font-size: 22rpx;
  color: #666;
}

.anomaly-text {
  font-size: 22rpx;
  color: #ff4d4f;
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
  padding: 10rpx 12rpx;
  border-radius: 10rpx;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.amount {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.actions {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.status-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #fff;
}

.status-tag.pending {
  background-color: #faad14;
}

.status-tag.processing {
  background-color: #1890ff;
}

.status-tag.shipped {
  background-color: #52c41a;
}

.status-tag.completed {
  background-color: #13c2c2;
}

.status-tag.cancelled {
  background-color: #999;
}

.anomaly-flag {
  font-size: 24rpx;
}

.action-btn {
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  border: 1rpx solid #1890ff;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #1890ff;
  background-color: #fff;
}

.action-btn.danger {
  border-color: #ff4d4f;
  color: #ff4d4f;
}

.empty-state {
  padding: 80rpx 20rpx;
  text-align: center;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading-state {
  padding: 30rpx 0;
  text-align: center;
  color: #666;
}

.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
  color: #666;
}

.no-more {
  color: #999;
}

.load-more-btn {
  background-color: #f0f0f0;
  color: #333;
  border: none;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

/* 详情弹层 */
.modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-panel {
  width: 92%;
  max-height: 80vh;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
}

.modal-body {
  padding: 20rpx;
  overflow-y: auto;
}

.detail-section {
  margin-bottom: 18rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx dashed #f0f0f0;
}

.detail-row .label {
  color: #666;
  font-size: 22rpx;
}

.detail-row .value {
  color: #333;
  font-size: 22rpx;
  max-width: 70%;
  text-align: right;
  word-break: break-all;
}

.detail-subtitle {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 22rpx;
  color: #333;
}

.detail-empty {
  color: #999;
  font-size: 22rpx;
  padding: 10rpx 0;
}