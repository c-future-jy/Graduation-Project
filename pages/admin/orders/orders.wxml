<view class="container">
  <view class="header">
    <text class="title">订单管理</text>
  </view>
  
  <!-- 搜索和筛选 -->
  <view class="search-filter">
    <view class="search-box">
      <input 
        class="search-input" 
        placeholder="输入订单号/用户/商家搜索" 
        bindinput="searchKeyword"
      />
      <button class="search-btn" bindtap="searchOrders">搜索</button>
    </view>
    <view class="filter-box">
      <picker class="filter-picker" bindchange="statusFilter">
        <view class="picker-text">
          状态：{{statusFilter === '' ? '全部' : statusFilter === '0' ? '待支付' : statusFilter === '1' ? '待发货' : statusFilter === '2' ? '已发货' : statusFilter === '3' ? '已完成' : '已取消'}}
        </view>
      </picker>
      <picker class="filter-picker" bindchange="timeRange">
        <view class="picker-text">
          时间范围：{{timeRange === '' ? '全部' : timeRange}}
        </view>
      </picker>
    </view>
  </view>

  <!-- 批量操作 -->
  <view class="batch-actions">
    <checkbox-group bindchange="selectAllOrders">
      <label class="checkbox-label">
        <checkbox value="all" />
        <text>全选</text>
      </label>
    </checkbox-group>
    <button class="batch-btn" bindtap="batchCancelOrders">批量取消</button>
  </view>

  <!-- 订单列表 -->
  <view class="orders-table">
    <view class="table-header">
      <view class="table-col select-col">选择</view>
      <view class="table-col id-col">订单号</view>
      <view class="table-col user-col">用户</view>
      <view class="table-col merchant-col">商家</view>
      <view class="table-col amount-col">金额</view>
      <view class="table-col status-col">状态</view>
      <view class="table-col time-col">下单时间</view>
      <view class="table-col action-col">操作</view>
    </view>
    <view class="table-body">
      <view wx:for="{{orders}}" wx:key="id" class="table-row">
        <view class="table-col select-col">
          <checkbox-group bindchange="selectOrder" data-id="{{item.id}}">
            <label class="checkbox-label">
              <checkbox value="{{item.id}}" checked="{{selectedOrders.includes(item.id)}}" />
            </label>
          </checkbox-group>
        </view>
        <view class="table-col id-col">{{item.id}}</view>
        <view class="table-col user-col">{{item.user}}</view>
        <view class="table-col merchant-col">{{item.merchant}}</view>
        <view class="table-col amount-col">¥{{item.amount.toFixed(2)}}</view>
        <view class="table-col status-col">
          <text class="status-tag {{item.status === '0' ? 'pending' : item.status === '1' ? 'processing' : item.status === '2' ? 'shipped' : item.status === '3' ? 'completed' : 'cancelled'}}">{{item.statusText}}</text>
        </view>
        <view class="table-col time-col">{{item.createdAt}}</view>
        <view class="table-col action-col">
          <button class="action-btn view" bindtap="viewOrderDetail" data-id="{{item.id}}">查看</button>
          <button class="action-btn dispute" bindtap="handleDispute" data-id="{{item.id}}">标记纠纷</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{orders.length === 0 && !loading}}" class="empty-state">
    <text class="empty-icon">📋</text>
    <text class="empty-text">未找到相关订单</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <!-- 分页信息 -->
  <view wx:if="{{orders.length > 0}}" class="pagination">
    <text>共 {{total}} 条记录</text>
    <text wx:if="{{!hasMore}}" class="no-more">没有更多数据了</text>
  </view>
</view>