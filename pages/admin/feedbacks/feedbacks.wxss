.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 24rpx;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.search-filter {
  background-color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 32rpx;
}

.filter-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.filter-row input {
  flex: 1;
  height: 68rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.filter-row .picker {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.search-btn {
  width: 120rpx;
  height: 68rpx;
  line-height: 68rpx;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.batch-operations {
  background-color: #fff;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.batch-operations text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.batch-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  border: 2rpx solid #1890ff;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #1890ff;
  background-color: #fff;
}

.batch-btn.primary {
  background-color: #1890ff;
  color: #fff;
}

.feedback-list {
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 卡片式布局 */
.feedback-card {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  padding: 24rpx;
  transition: all 0.3s ease;
}

.feedback-card:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
}

.card-header {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.checkbox-wrapper {
  margin-top: 4rpx;
}

.user-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.type-tag, .status-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

.status-info {
  margin-left: auto;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-btn.small {
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
}

.action-btn.secondary {
  background-color: #fff;
  color: #666;
  border-color: #d9d9d9;
}

.action-btn.secondary:hover {
  background-color: #f5f5f5;
  border-color: #1890ff;
  color: #1890ff;
}

.card-body {
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.rating-status-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.rating-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-info-card {
  margin-left: auto;
}

.rating-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #faad14;
}

.content-preview {
  background-color: #f8f9fa;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.content-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 操作内容展示 */
.action-content {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
}

.action-content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.action-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.action-toggle {
  font-size: 24rpx;
  color: #1890ff;
  cursor: pointer;
}

.action-content-body {
  margin-top: 12rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 操作输入框 */
.action-input {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: #f0f2f5;
  border-radius: 8rpx;
  border-top: 1rpx solid #e8e8e8;
  position: relative;
  z-index: 10;
}

.action-textarea {
  width: 100%;
  height: 160rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 26rpx;
  margin-bottom: 20rpx;
  resize: none;
  background-color: #fff;
}

.action-input-buttons {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.action-input-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  transition: all 0.2s;
}

.action-input-btn.cancel {
  background-color: #fff;
  color: #666;
  border: 2rpx solid #d9d9d9;
}

.action-input-btn.cancel:hover {
  background-color: #f5f5f5;
  border-color: #1890ff;
  color: #1890ff;
}

.action-input-btn.submit {
  background-color: #1890ff;
  color: #fff;
  border: none;
}

.action-input-btn.submit:hover {
  background-color: #40a9ff;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.time-info {
  font-size: 24rpx;
  color: #999;
  transition: all 0.2s;
}

.time-info:hover {
  color: #666;
}

.action-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  border: 2rpx solid #1890ff;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #1890ff;
  background-color: #fff;
  transition: all 0.2s;
}

.action-btn:hover {
  background-color: #e6f7ff;
}

.action-btn.primary {
  background-color: #1890ff;
  color: #fff;
}

.action-btn.primary:hover {
  background-color: #40a9ff;
}

.empty-state {
  padding: 160rpx 20rpx;
  text-align: center;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.empty-image {
  width: 280rpx;
  height: 280rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #bfbfbf;
  margin-bottom: 40rpx;
}

.reload-btn {
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 48rpx;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: background-color 0.2s;
}

.reload-btn:hover {
  background-color: #40a9ff;
}

.pagination {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 32rpx;
  padding: 0 12rpx;
}

.total-count {
  font-size: 26rpx;
  color: #666;
}

.page-btn {
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 36rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
  transition: all 0.2s;
}

.page-btn:hover {
  border-color: #1890ff;
  color: #1890ff;
}

.page-btn:disabled {
  color: #999;
  background-color: #f5f5f5;
  border-color: #e8e8e8;
}

.batch-modal {
  width: 80%;
  max-width: 500rpx;
}

.modal-content {
  padding: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.modal-info {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.reply-modal {
  width: 80%;
  max-width: 500rpx;
}

.feedback-info {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.feedback-content {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  line-height: 1.5;
}

.reply-textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  resize: none;
}

@media (max-width: 768px) {
  .filter-row {
    flex-direction: column;
    align-items: stretch;
  }
  
  .filter-row input,
  .filter-row .picker,
  .filter-row .search-btn {
    width: 100%;
  }
  
  .card-header {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .status-info {
    margin-left: 0;
    margin-top: 12rpx;
  }
  
  .card-footer {
    flex-direction: column;
    align-items: stretch;
    gap: 16rpx;
  }
  
  .action-btn {
    width: 100%;
  }
  
  .pagination {
    flex-direction: column;
    gap: 16rpx;
  }
  
  .total-count {
    order: -1;
  }
}
