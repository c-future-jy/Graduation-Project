<view class="container">
  <view class="header">
    <text class="title">反馈管理</text>
  </view>
  
  <!-- 搜索和筛选 -->
  <view class="search-filter">
    <view class="search-bar">
      <input type="text" placeholder="用户/内容关键词" bindinput="bindSearchInput" value="{{searchKeyword}}" />
      <button class="search-btn" bindtap="searchFeedbacks">搜索</button>
    </view>
    <view class="filter-row">
      <picker mode="selector" range="{{feedbackTypes}}" range-key="label" value="{{selectedType}}" bindchange="bindTypeChange">
        <view class="picker">
          <text>类型：{{feedbackTypes[selectedType].label}}</text>
        </view>
      </picker>
      <picker mode="selector" range="{{feedbackStatuses}}" range-key="label" value="{{selectedStatus}}" bindchange="bindStatusChange">
        <view class="picker">
          <text>状态：{{feedbackStatuses[selectedStatus].label}}</text>
        </view>
      </picker>
    </view>
  </view>
  
  <!-- 批量操作 -->
  <view class="batch-operations" wx:if="{{selectedFeedbacks.length > 0}}">
    <text>已选择 {{selectedFeedbacks.length}} 个反馈</text>
    <button class="batch-btn" bindtap="clearSelection">取消选择</button>
  </view>
  
  <!-- 反馈列表 -->
  <view class="feedback-list">
    <view class="table-container">
      <table class="feedback-table">
        <tr class="table-header">
          <th class="checkbox-col">
            <checkbox value="" checked="{{selectAll}}" bindchange="toggleSelectAll" />
          </th>
          <th>ID</th>
          <th>用户</th>
          <th>类型</th>
          <th>内容</th>
          <th>评分</th>
          <th>状态</th>
          <th>提交时间</th>
          <th>操作</th>
        </tr>
        <tr wx:for="{{feedbacks}}" wx:key="id" class="table-row">
          <td class="checkbox-col">
            <checkbox value="{{item.id}}" checked="{{selectedFeedbacks.indexOf(item.id) > -1}}" bindchange="toggleFeedbackSelection" data-id="{{item.id}}" />
          </td>
          <td>{{item.id}}</td>
          <td>{{item.userName}}</td>
          <td>
            <view class="type-tag" style="background-color: {{getTypeColor(item.type)}}">
              {{getTypeText(item.type)}}
            </view>
          </td>
          <td class="content-col">{{item.content}}</td>
          <td class="rating-col">
            <view class="rating">
              <text wx:for="[1, 2, 3, 4, 5]" wx:key="index" class="star {{index < item.rating ? 'active' : ''}}">★</text>
            </view>
          </td>
          <td>
            <view class="status-tag" style="background-color: {{getStatusColor(item.status)}}">
              {{getStatusText(item.status)}}
            </view>
          </td>
          <td>{{item.createdAt}}</td>
          <td class="action-col">
            <button class="action-btn" bindtap="viewFeedbackDetail" data-id="{{item.id}}">查看详情</button>
            <button class="action-btn" bindtap="replyFeedback" data-id="{{item.id}}" wx:if="{{item.status !== 'replied'}}">回复</button>
          </td>
        </tr>
      </table>
    </view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{feedbacks.length === 0}}">
      <image src="../../assets/images/empty.png" mode="aspectFit" class="empty-image" />
      <text class="empty-text">未找到相关反馈</text>
      <button class="reload-btn" bindtap="loadFeedbacks">重新加载</button>
    </view>
  </view>
  
  <!-- 分页 -->
  <view class="pagination" wx:if="{{feedbacks.length > 0}}">
    <button class="page-btn" bindtap="prevPage" disabled="{{currentPage === 1}}">上一页</button>
    <text>第 {{currentPage}} 页，共 {{totalPages}} 页</text>
    <button class="page-btn" bindtap="nextPage" disabled="{{currentPage === totalPages}}">下一页</button>
  </view>
</view>

<!-- 回复弹窗 -->
<modal class="reply-modal" wx:if="{{showReplyModal}}" hidden="{{!showReplyModal}}" bindconfirm="confirmReply" bindcancel="cancelReply">
  <view class="modal-content">
    <text class="modal-title">回复反馈</text>
    <text class="feedback-info">用户：{{currentFeedback.userName}}</text>
    <text class="feedback-info">类型：{{getTypeText(currentFeedback.type)}}</text>
    <text class="feedback-content">反馈内容：{{currentFeedback.content}}</text>
    <textarea placeholder="请输入回复内容" value="{{replyContent}}" bindinput="bindReplyContent" class="reply-textarea" />
  </view>
</modal>