/* pages/admin/dashboard/dashboard.wxss */
.dashboard-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面标题 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.refresh-btn {
  background-color: #1890ff;
  color: white;
  border: none;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.refresh-icon {
  font-size: 28rpx;
}

/* 统计卡片区域 */
.stats-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background-color: white;
  padding: 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
  cursor: pointer;
}

.stat-card:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.card-title {
  font-size: 24rpx;
  color: #666;
}

.card-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.trend-up {
  font-size: 20rpx;
  color: #52c41a;
}

.trend-down {
  font-size: 20rpx;
  color: #ff4d4f;
}

.trend-desc {
  font-size: 20rpx;
  color: #999;
}

/* 时间范围选择 */
.time-range {
  display: flex;
  gap: 12rpx;
  margin-bottom: 30rpx;
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.range-btn {
  flex: 1;
  background-color: #f0f0f0;
  border: none;
  padding: 12rpx 0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s;
}

.range-btn.active {
  background-color: #1890ff;
  color: white;
}

/* 图表区域 */
.chart-section {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.chart-card {
  background-color: white;
  padding: 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.chart-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.chart-container {
  height: 300rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
}

/* 模拟图表 */
.mock-chart {
  width: 100%;
  height: 100%;
}

/* 订单趋势图 */
.order-trend {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 100%;
}

.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar {
  width: 32rpx;
  background-color: #1890ff;
  border-radius: 4rpx 4rpx 0 0;
  margin-bottom: 8rpx;
  transition: height 0.5s ease;
}

.bar.sales {
  background-color: #52c41a;
}

.bar-label {
  font-size: 18rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.bar-value {
  font-size: 20rpx;
  color: #666;
  font-weight: bold;
}

/* 商家分类饼图 */
.pie-chart {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 100%;
}

.pie {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
}

.pie-slice {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  clip-path: polygon(50% 50%, 50% 0%, 100% 0%, 100% 100%, 50% 100%);
  transform-origin: 50% 50%;
  background-color: var(--color, #1890ff);
}

.pie-slice:nth-child(1) {
  --color: #1890ff;
  transform: rotate(0deg) translateX(-80rpx);
}

.pie-slice:nth-child(2) {
  --color: #52c41a;
  transform: rotate(163deg) translateX(-80rpx);
}

.pie-slice:nth-child(3) {
  --color: #faad14;
  transform: rotate(273deg) translateX(-80rpx);
}

.pie-slice:nth-child(4) {
  --color: #ff4d4f;
  transform: rotate(327deg) translateX(-80rpx);
}

.pie-legend {
  flex: 1;
  margin-left: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 8rpx;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  background-color: var(--color, #1890ff);
}

.legend-color:nth-child(1) {
  --color: #1890ff;
}

.legend-color:nth-child(2) {
  --color: #52c41a;
}

.legend-color:nth-child(3) {
  --color: #faad14;
}

.legend-color:nth-child(4) {
  --color: #ff4d4f;
}

.legend-name {
  flex: 1;
  font-size: 20rpx;
  color: #666;
}

.legend-value {
  font-size: 20rpx;
  color: #333;
  font-weight: bold;
}

/* 快捷入口 */
.quick-access {
  background-color: white;
  padding: 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.access-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.access-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.access-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  cursor: pointer;
  transition: all 0.3s;
  border: 1rpx solid #e8e8e8;
}

.access-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border-color: #1890ff;
}

.access-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.access-name {
  font-size: 20rpx;
  color: #666;
}

/* 响应式适配 */
@media (max-width: 768px) {
  .stats-cards {
    grid-template-columns: 1fr;
  }
  
  .chart-section {
    grid-template-columns: 1fr;
  }
  
  .access-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}