/* 管理后台首页样式 */
.dashboard-container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 顶部用户信息栏 */
.user-info-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.user-details {
  flex: 1;
}

.greeting {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.current-time {
  font-size: 24rpx;
  color: #666;
}

.notification-icon {
  position: relative;
  cursor: pointer;
  padding: 12rpx;
  border-radius: 50%;
  transition: all 0.3s;
}

.notification-icon:hover {
  background-color: #f0f7ff;
}

.notification-icon .icon {
  font-size: 36rpx;
}

.notification-badge {
  position: absolute;
  top: 0;
  right: 0;
  background-color: #ff4d4f;
  color: white;
  font-size: 20rpx;
  font-weight: bold;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  padding: 0 8rpx;
}

/* 标题样式 */
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin: 32rpx 0 16rpx;
}

/* 数据概览卡片 */
.stats-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
  cursor: pointer;
}

.stat-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  color: #1890ff;
}

.card-title {
  font-size: 24rpx;
  color: #666;
}

.card-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.trend-up {
  font-size: 20rpx;
  color: #52c41a;
  font-weight: bold;
}

.trend-down {
  font-size: 20rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.trend-desc {
  font-size: 20rpx;
  color: #999;
}

/* 待处理事项 */
.pending-tasks {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.task-card {
  display: flex;
  align-items: center;
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
  cursor: pointer;
}

.task-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.task-card.urgent {
  border-left: 8rpx solid #ff4d4f;
}

.task-card.warning {
  border-left: 8rpx solid #faad14;
}

.task-card.info {
  border-left: 8rpx solid #999;
}

.task-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.task-info {
  flex: 1;
}

.task-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
  display: block;
}

.task-desc {
  font-size: 22rpx;
  color: #666;
}

.task-badge {
  font-size: 24rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.task-badge.urgent {
  background-color: #fff2f0;
  color: #ff4d4f;
}

.task-badge.warning {
  background-color: #fffbe6;
  color: #faad14;
}

.task-badge.info {
  background-color: #f5f5f5;
  color: #999;
}

/* 快捷操作 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
  cursor: pointer;
  border: 1rpx solid #e8e8e8;
}

.action-button:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  border-color: #1890ff;
}

.action-icon {
  font-size: 48rpx;
  color: #1890ff;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 数据趋势图 */
.trend-chart {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.chart-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.chart-toggle {
  display: flex;
  gap: 8rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  padding: 4rpx;
}

.toggle-item {
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  color: #666;
  cursor: pointer;
  transition: all 0.3s;
}

.toggle-item.active {
  background-color: white;
  color: #1890ff;
  font-weight: bold;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.chart-container {
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.chart-placeholder {
  text-align: center;
}

.chart-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  display: block;
}

.chart-desc {
  font-size: 24rpx;
  color: #999;
}

/* 响应式适配 */
@media (max-width: 768px) {
  .stats-cards {
    grid-template-columns: 1fr;
  }
  
  .quick-actions {
    grid-template-columns: 1fr;
  }
  
  .dashboard-container {
    padding: 16rpx;
  }
  
  .user-info-bar {
    padding: 16rpx;
  }
  
  .stat-card,
  .task-card,
  .action-button,
  .trend-chart {
    padding: 16rpx;
  }
}

/* 滚动条样式 */
.dashboard-container::-webkit-scrollbar {
  width: 6rpx;
}

.dashboard-container::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 3rpx;
}

.dashboard-container::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 3rpx;
}

.dashboard-container::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}