/* pages/admin/products/products.wxss */
.products-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面标题 */
.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 搜索和筛选 */
.search-filter {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.search-btn {
  background-color: #1890ff;
  color: white;
  border: none;
  padding: 0 32rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.filter-box {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.filter-picker {
  flex: 1;
  min-width: 200rpx;
  height: 60rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

/* 批量操作 */
.batch-actions {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.checkbox-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.batch-btn {
  background-color: #f0f0f0;
  color: #333;
  border: none;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

/* 数据监督 */
.supervise-bar {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  font-size: 22rpx;
  color: #666;
}

/* 商品列表 */
.products-table {
  background-color: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  margin-bottom: 20rpx;
}

.table-scroll {
  width: 100%;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
}

.table-inner {
  display: inline-block;
  min-width: 1230rpx;
}

.table-header {
  display: flex;
  background-color: #f9f9f9;
  border-bottom: 1rpx solid #e8e8e8;
  padding: 16rpx 20rpx;
  font-weight: bold;
  font-size: 22rpx;
  color: #333;
  box-sizing: border-box;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #e8e8e8;
  padding: 20rpx;
  align-items: center;
  transition: background-color 0.3s;
  box-sizing: border-box;
}

.table-row:hover {
  background-color: #f9f9f9;
}

.table-col {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  box-sizing: border-box;
  padding: 0 12rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.select-col {
  width: 80rpx;
  justify-content: center;
  padding: 0;
}

.id-col {
  width: 80rpx;
  color: #666;
  justify-content: center;
}

.name-col {
  width: 220rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  justify-content: flex-start;
}

.merchant-col {
  width: 150rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  justify-content: flex-start;
}

.category-col {
  width: 100rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  justify-content: center;
}

.price-col {
  width: 120rpx;
  color: #ff4d4f;
  font-weight: bold;
  gap: 6rpx;
  white-space: nowrap;
  justify-content: center;
}

.stock-col {
  width: 120rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  white-space: nowrap;
  justify-content: center;
}

.stock-text {
  font-size: 22rpx;
  color: #333;
}

.stock-text.low-stock {
  color: #ff4d4f;
  font-weight: bold;
}

.stock-warning {
  font-size: 24rpx;
}

.status-col {
  width: 100rpx;
  justify-content: center;
}

.action-col {
  width: 280rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  justify-content: center;
  align-items: center;
}

/* 状态标签 */
.status-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.status-tag.online {
  background-color: #f6ffed;
  color: #52c41a;
}

.status-tag.offline {
  background-color: #f5f5f5;
  color: #999;
}

/* 操作按钮 */
.action-btn {
  width: 160rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
  border-radius: 6rpx;
  font-size: 20rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.view {
  background-color: #e6f7ff;
  color: #1890ff;
}

.action-btn.edit {
  background-color: #fff7e6;
  color: #faad14;
}

.action-btn.offline {
  background-color: #fff1f0;
  color: #ff4d4f;
}

.action-btn.online {
  background-color: #f6ffed;
  color: #52c41a;
}

/* 空状态 */
.empty-state {
  background-color: white;
  padding: 80rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  text-align: center;
  margin-bottom: 20rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  display: block;
  margin: 0 auto 20rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  background-color: white;
  padding: 40rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  text-align: center;
  margin-bottom: 20rpx;
  color: #666;
}

/* 分页信息 */
.pagination {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 20rpx;
  color: #666;
}

.load-more-btn {
  background-color: #1890ff;
  color: #fff;
  border: none;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  line-height: 1;
}

.no-more {
  color: #999;
}

/* 响应式适配 */
@media (max-width: 768px) {
  .products-table {
    overflow-x: auto;
  }
  
  .table-header,
  .table-row {
    min-width: 1400rpx;
  }
  
  .search-box {
    flex-direction: column;
  }
  
  .filter-box {
    flex-direction: column;
  }
  
  .batch-actions {
    flex-wrap: wrap;
  }
  
  .action-col {
    flex-wrap: wrap;
  }
}