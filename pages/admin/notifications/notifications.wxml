<view class="container">
  <view class="header">
    <text class="title">通知管理</text>
    <button class="publish-btn" bindtap="showPublishModal">发布通知</button>
  </view>
  
  <!-- 悬浮发布按钮 -->
  <button class="floating-publish-btn" bindtap="showPublishModal">+</button>
  
    <!-- 统计卡片 -->
  <view class="stats-container">
    <view class="stat-card total" bindtap="filterByType">
      <view class="stat-icon">🔔</view>
      <text class="stat-number">{{readStats.total || 0}}</text>
      <text class="stat-label">总通知数</text>
    </view>
    <view class="stat-card read" bindtap="filterByRead">
      <view class="stat-icon">✓</view>
      <text class="stat-number">{{readStats.readCount || 0}}</text>
      <text class="stat-label">已读通知</text>
    </view>
    <view class="stat-card unread" bindtap="filterByUnread">
      <view class="stat-icon red-dot">●</view>
      <text class="stat-number highlight">{{readStats.unreadCount || 0}}</text>
      <text class="stat-label">未读通知</text>
    </view>
    <view class="stat-card rate">
      <view class="progress-container">
        <view class="progress-ring">
          <svg width="80" height="80" viewBox="0 0 80 80">
            <circle class="progress-background" cx="40" cy="40" r="36" />
            <circle class="progress-bar" cx="40" cy="40" r="36" 
                    style="stroke-dasharray: {{2 * Math.PI * 36}}; stroke-dashoffset: {{2 * Math.PI * 36 * (1 - (progressAngle || 0) / 360)}}" />
          </svg>
          <text class="progress-text">{{readStats.readRate || '0%'}}</text>
        </view>
      </view>
      <text class="stat-label">已读率</text>
    </view>
  </view>
  
  <!-- 搜索和筛选 -->
  <view class="search-filter">
    <view class="search-bar">
      <view class="search-input-container">
        <input type="text" placeholder="标题关键词" bindinput="bindSearchInput" value="{{searchKeyword}}" bindconfirm="searchNotifications" />
        <view class="clear-btn" wx:if="{{searchKeyword}}" bindtap="clearSearch">×</view>
        <button class="search-btn" bindtap="searchNotifications">搜索</button>
      </view>
    </view>
    <scroll-view scroll-x="true" class="filter-scroll-view">
      <view class="filter-row">
        <picker mode="selector" range="{{notificationTypes}}" range-key="label" value="{{selectedType}}" bindchange="bindTypeChange">
          <view class="picker">
            <view class="filter-tag {{selectedType !== 0 ? 'active' : ''}}">
              <text class="filter-tag-label">类型：</text>
              <text class="filter-tag-value {{selectedType !== 0 ? 'active' : ''}}">{{notificationTypes[selectedType].label}}</text>
            </view>
          </view>
        </picker>
        <picker mode="selector" range="{{readStatuses}}" range-key="label" value="{{selectedReadStatus}}" bindchange="bindReadStatusChange">
          <view class="picker">
            <view class="filter-tag {{selectedReadStatus !== 0 ? 'active' : ''}}">
              <text class="filter-tag-label">已读状态：</text>
              <text class="filter-tag-value {{selectedReadStatus !== 0 ? 'active' : ''}}">{{readStatuses[selectedReadStatus].label}}</text>
            </view>
          </view>
        </picker>
        <view class="date-range-picker {{(startDate || endDate) ? 'active' : ''}}" bindtap="openDatePickerModal">
          <view class="date-picker-item">
            <text class="date-label">日期范围</text>
            <text class="date-value {{(startDate || endDate) ? 'active' : ''}}">{{dateRangeText || '选择'}}</text>
          </view>
        </view>
        <button class="reset-btn" bindtap="resetFilters" wx:if="{{hasActiveFilters}}" style="background-color: {{hasActiveFilters ? '#1890ff' : '#f5f5f5'}}; color: {{hasActiveFilters ? '#fff' : '#999'}};">重置</button>
      </view>
    </scroll-view>
  </view>
  
  <!-- 批量操作 -->
  <view class="batch-operations" wx:if="{{selectedNotifications.length > 0}}">
    <text>已选择 {{selectedNotifications.length}} 个通知</text>
    <button class="batch-btn" bindtap="batchDelete">批量删除</button>
    <button class="batch-btn" bindtap="batchMarkAsRead">批量标记已读</button>
    <button class="batch-btn" bindtap="clearSelection">取消选择</button>
  </view>
  
  <!-- 通知列表 -->
  <view class="notification-list">
    <!-- 加载动画 -->
    <view class="loading-container" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
    
<!-- 表格外层滚动容器 -->
<scroll-view scroll-x="true" class="table-scroll-container">
  <view class="table-container" wx:if="{{!loading}}">
    <!-- 表头：统一单元格对齐方式 -->
    <view class="table-row table-header">
      <view class="table-cell cell-checkbox"><checkbox value="" checked="{{selectAll}}" bindchange="toggleSelectAll" /></view>
      <view class="table-cell cell-id">ID</view>
      <view class="table-cell cell-title">标题</view>
      <view class="table-cell cell-type">类型</view>
      <view class="table-cell cell-scope">接收范围</view>
      <view class="table-cell cell-time">发送时间</view>
      <view class="table-cell cell-operate">操作</view>
    </view>

    <!-- 内容列表 -->
    <view class="table-row" wx:for="{{notifications}}" wx:key="id">
      <view class="table-cell cell-checkbox"><checkbox value="{{item.id}}" checked="{{selectedNotifications.indexOf(item.id) > -1}}" bindchange="toggleNotificationSelection" data-id="{{item.id}}" /></view>
      <view class="table-cell cell-id">{{item.id}}</view>
      <view class="table-cell cell-title">{{item.title}}</view>
      <view class="table-cell cell-type">
        <text>{{item.formattedType}}</text>
      </view>
      <view class="table-cell cell-scope">
        <text>{{getScopeText(item.receiveScope)}}</text>
        <text class="read-tag">已读{{item.readCount}}/未读{{item.unreadCount}}</text>
      </view>
      <view class="table-cell cell-time">
        <text>{{item.formattedTime}}</text>
      </view>
      <view class="table-cell cell-operate">
        <text class="btn-read" wx:if="{{!item.isRead}}" bindtap="markAsRead" data-id="{{item.id}}">标记已读</text>
        <text class="btn-delete" bindtap="deleteNotification" data-id="{{item.id}}">删除</text>
      </view>
    </view>
  </view>
</scroll-view>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && notifications.length === 0}}">
      <image class="empty-icon" src="/assets/images/kong.jpg" mode="aspectFit" />
      <text class="empty-text">{{hasActiveFilters ? '未找到匹配的通知，可调整筛选条件试试' : '暂无通知，点击「发布通知」创建第一条吧'}}</text>
      <view class="empty-actions">
        <button class="reload-btn" bindtap="loadNotifications">重新加载</button>
        <button wx:if="{{hasActiveFilters}}" class="reset-btn" bindtap="resetFilters">重置筛选</button>
        <button wx:else class="publish-btn" bindtap="showPublishModal">发布通知</button>
      </view>
    </view>
  </view>
  
  <!-- 分页 -->
  <view class="pagination" wx:if="{{notifications.length > 0}}">
    <button class="page-btn" bindtap="prevPage" disabled="{{currentPage === 1}}">上一页</button>
    <text>第 {{currentPage}} 页，共 {{totalPages}} 页</text>
    <button class="page-btn" bindtap="nextPage" disabled="{{currentPage === totalPages}}">下一页</button>
  </view>
</view>

<!-- 发布通知弹窗 -->
<modal class="publish-modal" wx:if="{{showPublishModal}}" hidden="{{!showPublishModal}}" bindconfirm="publishNotification" bindcancel="cancelPublish">
  <view class="modal-content">
    <text class="modal-title">发布通知</text>
    <view class="form-item">
      <text class="form-label">标题</text>
      <input type="text" placeholder="请输入通知标题" value="{{publishForm.title}}" bindinput="bindPublishFormInput" data-field="title" class="form-input" />
    </view>
    <view class="form-item">
      <text class="form-label">内容</text>
      <textarea placeholder="请输入通知内容" value="{{publishForm.content}}" bindinput="bindPublishFormInput" data-field="content" class="form-textarea" />
    </view>
    <view class="form-item">
      <text class="form-label">类型</text>
      <picker mode="selector" range="{{notificationTypes}}" range-key="label" bindchange="bindTypeChangePublish">
        <view class="form-picker">
          <text>{{publishForm.typeText || '请选择类型'}}</text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">接收范围</text>
      <picker mode="selector" range="{{receiveScopes}}" range-key="label" bindchange="bindScopeChange">
        <view class="form-picker">
          <text>{{publishForm.receiveScopeText}}</text>
        </view>
      </picker>
    </view>

  </view>
</modal>

<!-- 日期选择弹窗 -->
<view class="date-picker-modal" wx:if="{{showDatePickerModal}}">
  <view class="modal-overlay" bindtap="closeDatePickerModal"></view>
  <view class="modal-content date-picker-content">
    <view class="modal-header">
      <text class="modal-title">选择日期范围</text>
      <text class="close-btn" bindtap="closeDatePickerModal">×</text>
    </view>
    <view class="date-quick-options">
      <button class="quick-option-btn" bindtap="setDateRange(7)">最近7天</button>
      <button class="quick-option-btn" bindtap="setDateRange(30)">最近30天</button>
      <button class="quick-option-btn" bindtap="clearDateRange">全部</button>
    </view>
    <view class="date-pickers">
      <view class="date-picker-item">
        <text class="date-picker-label">开始日期</text>
        <picker mode="date" start="2020-01-01" end="2026-12-31" value="{{startDate}}" bindchange="bindStartDateChange">
          <view class="date-picker-input">
            <text>{{startDate || '选择'}}</text>
          </view>
        </picker>
      </view>
      <view class="date-picker-item">
        <text class="date-picker-label">结束日期</text>
        <picker mode="date" start="{{startDate || '2020-01-01'}}" end="2026-12-31" value="{{endDate}}" bindchange="bindEndDateChange">
          <view class="date-picker-input">
            <text>{{endDate || '选择'}}</text>
          </view>
        </picker>
      </view>
    </view>
    <view class="modal-footer">
      <button class="cancel-btn" bindtap="closeDatePickerModal">取消</button>
      <button class="confirm-btn" bindtap="confirmDateRange">确定</button>
    </view>
  </view>
</view>