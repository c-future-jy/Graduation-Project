.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.publish-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 30rpx;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.search-filter {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
}

.search-bar {
  display: flex;
  margin-bottom: 20rpx;
}

.search-bar input {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-right: 10rpx;
}

.search-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.filter-row {
  display: flex;
  gap: 20rpx;
}

.picker {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.batch-operations {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.batch-operations text {
  font-size: 28rpx;
  color: #333;
}

.batch-btn {
  height: 50rpx;
  line-height: 50rpx;
  padding: 0 20rpx;
  border: 1rpx solid #1890ff;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #1890ff;
  background-color: #fff;
}

.notification-list {
  background-color: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.table-container {
  overflow-x: auto;
}

.notification-table {
  width: 100%;
  border-collapse: collapse;
}

.table-header {
  background-color: #fafafa;
}

.table-header th {
  padding: 20rpx;
  text-align: left;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  border-bottom: 2rpx solid #e8e8e8;
}

.table-row {
  border-bottom: 1rpx solid #e8e8e8;
}

.table-row td {
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
}

.checkbox-col {
  width: 80rpx;
  text-align: center;
}

.title-col {
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.type-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #fff;
}

.read-status {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.unread {
  color: #ff4d4f;
}

.action-col {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.action-btn {
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  border: 1rpx solid #1890ff;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #1890ff;
  background-color: #fff;
}

.action-btn.danger {
  border-color: #ff4d4f;
  color: #ff4d4f;
}

.empty-state {
  padding: 80rpx 20rpx;
  text-align: center;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.reload-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 40rpx;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.page-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 30rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
}

.page-btn:disabled {
  color: #999;
  background-color: #f5f5f5;
}

.publish-modal {
  width: 80%;
  max-width: 500rpx;
}

.modal-content {
  padding: 20rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.form-input {
  width: 100%;
  height: 60rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  height: 150rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  resize: none;
}

.form-picker {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}

@media (max-width: 768px) {
  .header {
    flex-direction: column;
    align-items: flex-start;
    gap: 10rpx;
  }
  
  .publish-btn {
    width: 100%;
  }
  
  .action-col {
    flex-direction: column;
  }
  
  .action-btn {
    width: 100%;
  }
}