}
.quick-option-btn {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #fff;
}
.date-pickers {
  margin-bottom: 32rpx;
}
.date-picker-item {
  margin-bottom: 20rpx;
}
.date-picker-label {
  display: block;
  font-size: 26rpx;
  color: #8A8F98;
  margin-bottom: 8rpx;
}
.date-picker-input {
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e8e8;
