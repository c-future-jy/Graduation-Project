/* pages/admin/index.wxss */
.admin-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.admin-header {
  height: 60rpx;
  background-color: #1890ff;
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.header-left .logo {
  font-size: 32rpx;
  font-weight: bold;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid white;
}

.user-name {
  font-size: 28rpx;
}

.logout-btn {
  background-color: rgba(255, 255, 255, 0.2);
  color: white;
  border: none;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 内容区域 */
.admin-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧菜单 */
.admin-sidebar {
  width: 240rpx;
  background-color: white;
  border-right: 1rpx solid #e8e8e8;
  padding: 20rpx 0;
  overflow-y: auto;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin: 10rpx 10rpx;
  border-radius: 8rpx;
  cursor: pointer;
  transition: all 0.3s;
}

.menu-item:hover {
  background-color: #f0f7ff;
}

.menu-item.active {
  background-color: #e6f7ff;
  color: #1890ff;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.menu-name {
  font-size: 28rpx;
}

/* 右侧内容区 */
.admin-main {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

/* 欢迎区域 */
.welcome-section {
  background-color: white;
  padding: 40rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #666;
}

/* 管理概览 */
.dashboard-preview {
  background-color: white;
  padding: 30rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.preview-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

.preview-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.preview-card {
  background-color: #f9f9f9;
  padding: 30rpx;
  border-radius: 8rpx;
  text-align: center;
  transition: all 0.3s;
  border: 1rpx solid #e8e8e8;
}

.preview-card:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border-color: #1890ff;
}

.card-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  color: #333;
}

.card-desc {
  font-size: 24rpx;
  color: #666;
}

/* 响应式适配 */
@media (max-width: 768px) {
  .admin-sidebar {
    width: 200rpx;
  }
  
  .menu-name {
    font-size: 24rpx;
  }
  
  .preview-cards {
    grid-template-columns: 1fr;
  }
}