/* pages/admin/index.wxss */
.admin-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.admin-header {
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.header-left .logo {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid white;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.user-details {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: bold;
}

.user-role {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}



/* 内容区域 */
.admin-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧菜单 */
.admin-sidebar {
  width: 480rpx; /* 240px */
  background-color: #ffffff;
  border-right: 1rpx solid #e8e8e8;
  padding: 24rpx 0; /* 上下12px */
  overflow-y: auto;
  box-shadow: 2rpx 0 8rpx rgba(0, 0, 0, 0.05);
}

/* 顶部LOGO区域 */
.sidebar-header {
  padding: 0 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.logo {
  font-size: 32rpx;
  font-weight: bold;
  color: #1677ff;
  display: block;
}

/* 菜单分类 */
.menu-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 24rpx; /* 12px */
  font-weight: 500;
  color: #999999;
  padding: 16rpx 32rpx 8rpx;
  margin-bottom: 8rpx;
}

/* 菜单项 */
.menu-item {
  display: flex;
  align-items: center;
  height: 88rpx; /* 44px */
  padding: 0 32rpx;
  margin: 4rpx 16rpx;
  border-radius: 8rpx;
  cursor: pointer;
  transition: all 0.2s ease;
  position: relative;
  color: #333333;
  font-size: 28rpx;
  white-space: nowrap;
  overflow: visible;
  text-overflow: clip;
}

.menu-item:hover {
  background-color: #f5f7fa;
}

.menu-item.active {
  background-color: #e6f0ff;
  color: #1677ff;
  font-weight: 500;
}

.menu-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 16rpx; /* 8px */
  width: 8rpx; /* 4px */
  height: 56rpx; /* 28px */
  background: #1677ff;
  border-radius: 4rpx; /* 2px */
}

.menu-name {
  flex: 1;
  font-size: 28rpx;
  font-family: 'PingFang SC', 'Source Han Sans', sans-serif;
  white-space: nowrap;
  overflow: visible;
  text-overflow: clip;
}

/* 底部区域 */
.sidebar-footer {
  margin-top: 32rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.footer-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  color: #666666;
  font-size: 28rpx;
  cursor: pointer;
  transition: all 0.2s ease;
}

.footer-button:hover {
  background-color: #e6f0ff;
  color: #1677ff;
}

.footer-button .menu-name {
  text-align: center;
}

/* 右侧内容区 */
.admin-main {
  flex: 1;
  padding: 40rpx;
  overflow-y: auto;
}

/* 欢迎区域 */
.welcome-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  margin-bottom: 40rpx;
  text-align: center;
}

/* 第一行：欢迎标题 */
.welcome-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  line-height: 1.3;
  display: block;      /* 确保独占一行 */
  margin-bottom: 16rpx; /* 与第二行间距 */
}

/* 第二行：日期时间 */
.welcome-datetime {
  font-size: 26rpx;
  color: #FFFFFF;
  line-height: 1.4;
  display: block;      /* 确保独占一行 */
  margin: 12rpx 0;     /* 上下都有间距 */
}

/* 第三行：祝福语 */
.welcome-blessing {
  font-size: 24rpx;
  color: #FFFFFF;
  line-height: 1.4;
  display: block;      /* 确保独占一行 */
  margin-top: 12rpx;   /* 与第二行间距 */
}

/* 管理概览 */
.dashboard-preview {
  background-color: white;
  padding: 40rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.preview-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 36rpx;
  color: #333;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.preview-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.preview-card {
  background-color: #ffffff;
  padding: 32rpx;
  border-radius: 16rpx;
  text-align: center;
  transition: all 0.3s;
  border: 1rpx solid #e8e8e8;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  position: relative;
  overflow: hidden;
}

.preview-card:nth-child(1) {
  border-left: 4rpx solid #667eea;
}

.preview-card:nth-child(2) {
  border-left: 4rpx solid #52c41a;
}

.preview-card:nth-child(3) {
  border-left: 4rpx solid #fa8c16;
}

.preview-card:nth-child(4) {
  border-left: 4rpx solid #ff4d4f;
}

.preview-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  border-color: #1890ff;
}

.card-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
  display: block;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  color: #333;
  line-height: 1.2;
}

.card-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  margin-top: 0;
}

/* 响应式适配 */
@media (max-width: 768px) {
  .admin-sidebar {
    width: 220rpx;
  }
  
  .menu-name {
    font-size: 26rpx;
  }
  
  .preview-cards {
    grid-template-columns: 1fr;
  }
  
  .admin-main {
    padding: 20rpx;
  }
  
  .welcome-section,
  .dashboard-preview {
    padding: 24rpx;
  }
}

/* 滚动条样式 */
.admin-sidebar::-webkit-scrollbar {
  width: 6rpx;
}

.admin-sidebar::-webkit-scrollbar-track {
  background: #f1f1f1;
}

.admin-sidebar::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 3rpx;
}

.admin-sidebar::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}