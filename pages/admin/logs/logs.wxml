<!-- pages/admin/logs/logs.wxml -->
<view class="container">
  <!-- 顶部筛选栏 -->
  <view class="filter-bar">
    <text class="title">操作日志</text>
    <button class="filter-btn" bindtap="toggleFilters">
      筛选
      <text class="arrow">{{showFilters ? '▲' : '▼'}}</text>
    </button>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel" wx:if="{{showFilters}}">
    <view class="filter-item">
      <text class="filter-label">管理员ID</text>
      <input 
        class="filter-input" 
        placeholder="输入管理员ID" 
        value="{{filters.admin_id}}" 
        bindinput="onFilterInput" 
        data-key="admin_id"
      />
    </view>
    <view class="filter-item">
      <text class="filter-label">操作类型</text>
      <input 
        class="filter-input" 
        placeholder="输入操作类型" 
        value="{{filters.operation}}" 
        bindinput="onFilterInput" 
        data-key="operation"
      />
    </view>
    <view class="filter-item">
      <text class="filter-label">开始时间</text>
      <input 
        class="filter-input" 
        placeholder="YYYY-MM-DD HH:MM:SS" 
        value="{{filters.startTime}}" 
        bindinput="onFilterInput" 
        data-key="startTime"
      />
    </view>
    <view class="filter-item">
      <text class="filter-label">结束时间</text>
      <input 
        class="filter-input" 
        placeholder="YYYY-MM-DD HH:MM:SS" 
        value="{{filters.endTime}}" 
        bindinput="onFilterInput" 
        data-key="endTime"
      />
    </view>
    <view class="filter-actions">
      <button class="reset-btn" bindtap="resetFilters">重置</button>
      <button class="apply-btn" bindtap="applyFilters">应用</button>
    </view>
  </view>

  <!-- 日志列表 -->
  <view class="logs-list" wx:if="{{logs.length > 0}}">
    <view class="log-item" wx:for="{{logs}}" wx:key="id">
      <view class="log-header">
        <text class="operation">{{item.operation}}</text>
        <text class="time">{{formatTime(item.created_at)}}</text>
      </view>
      <view class="log-info">
        <view class="info-row">
          <text class="label">管理员：</text>
          <text class="value">{{item.admin_name || item.admin_id}}</text>
        </view>
        <view class="info-row" wx:if="{{item.target_product_id}}">
          <text class="label">商品ID：</text>
          <text class="value">{{item.target_product_id}}</text>
        </view>
        <view class="info-row" wx:if="{{item.target_merchant_id}}">
          <text class="label">商家ID：</text>
          <text class="value">{{item.target_merchant_id}}</text>
        </view>
        <view class="info-row" wx:if="{{item.target_user_id}}">
          <text class="label">用户ID：</text>
          <text class="value">{{item.target_user_id}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{logs.length === 0 && !loading}}">
    <text class="empty-text">暂无操作日志</text>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:if="{{error}}">
    <text class="error-text">加载失败</text>
    <button class="retry-btn" bindtap="retry">重试</button>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{!loading && logs.length > 0 && page < totalPages}}">
    <text class="load-more-text">上拉加载更多</text>
  </view>
</view>
