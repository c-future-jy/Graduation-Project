/* pages/admin/users/users.wxss */
.users-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面标题 */
.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 搜索和筛选 */
.search-filter {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.search-btn {
  background-color: #1890ff;
  color: white;
  border: none;
  padding: 0 32rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.filter-box {
  display: flex;
  gap: 20rpx;
}

.filter-picker {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

/* 批量操作 */
.batch-actions {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.checkbox-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.batch-btn {
  background-color: #f0f0f0;
  color: #333;
  border: none;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

/* 用户列表 */
.users-table {
  background-color: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  margin-bottom: 20rpx;
}

.table-scroll {
  overflow-x: auto;
  overflow-y: hidden;
}

.table-header {
  display: flex;
  background-color: #f9f9f9;
  border-bottom: 1rpx solid #e8e8e8;
  padding: 16rpx 20rpx;
  font-weight: bold;
  font-size: 22rpx;
  color: #333;
  min-width: 1200rpx;
  box-sizing: border-box;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #e8e8e8;
  padding: 16rpx 20rpx;
  align-items: center;
  transition: background-color 0.3s;
  min-width: 1200rpx;
  box-sizing: border-box;
  min-height: 76rpx;
}

.table-row:hover {
  background-color: #f9f9f9;
}

.table-col {
  display: flex;
  align-items: center;
  padding: 0 10rpx;
  box-sizing: border-box;
  min-width: 0;
  white-space: nowrap;
}

.select-col {
  flex: 0 0 80rpx;
  justify-content: center;
}

.id-col {
  flex: 0 0 90rpx;
  color: #666;
}

.name-col {
  flex: 0 0 220rpx;
  color: #333;
}

.phone-col {
  flex: 0 0 200rpx;
  color: #666;
}

.role-col {
  flex: 0 0 120rpx;
  justify-content: center;
}

.status-col {
  flex: 0 0 120rpx;
  justify-content: center;
}

.time-col {
  flex: 0 0 240rpx;
  color: #999;
  font-size: 20rpx;
}

.action-col {
  flex: 0 0 320rpx;
  display: flex;
  gap: 8rpx;
  justify-content: flex-end;
  flex-wrap: nowrap;
}

.cell-ellipsis {
  display: block;
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* 角色标签 */
.role-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.role-tag.admin {
  background-color: #fff1f0;
  color: #ff4d4f;
}

.role-tag.student {
  background-color: #e6f7ff;
  color: #1890ff;
}

.role-tag.merchant {
  background-color: #f6ffed;
  color: #52c41a;
}

/* 状态标签 */
.status-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.status-tag.normal {
  background-color: #f6ffed;
  color: #52c41a;
}

.status-tag.disabled {
  background-color: #f5f5f5;
  color: #999;
}

/* 操作按钮 */
.action-btn {
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  border: none;
  height: 44rpx;
  line-height: 44rpx;
}

.action-btn.view {
  background-color: #e6f7ff;
  color: #1890ff;
}

.action-btn.disable {
  background-color: #fff1f0;
  color: #ff4d4f;
}

.action-btn.enable {
  background-color: #f6ffed;
  color: #52c41a;
}

.action-btn.reset {
  background-color: #fff7e6;
  color: #faad14;
}

/* 空状态 */
.empty-state {
  background-color: white;
  padding: 80rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  text-align: center;
  margin-bottom: 20rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  display: block;
  margin: 0 auto 20rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  background-color: white;
  padding: 40rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  text-align: center;
  margin-bottom: 20rpx;
  color: #666;
}

/* 分页信息 */
.pagination {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 20rpx;
  color: #666;
}

.no-more {
  color: #999;
}

/* 用户详情弹窗 */
.detail-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  z-index: 999;
}

.detail-panel {
  width: 100%;
  max-width: 680rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.detail-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.detail-close {
  font-size: 40rpx;
  line-height: 40rpx;
  color: #999;
  padding: 0 10rpx;
}

.detail-loading {
  padding: 40rpx 20rpx;
  text-align: center;
  color: #666;
}

.detail-content {
  max-height: 75vh;
  padding: 20rpx;
  box-sizing: border-box;
}

.detail-section {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  font-size: 22rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.detail-label {
  font-size: 22rpx;
  color: #666;
  flex: 0 0 160rpx;
}

.detail-value {
  font-size: 22rpx;
  color: #333;
  flex: 1;
  text-align: right;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.detail-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.detail-avatar.placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-left: auto;
}

/* 响应式适配 */
@media (max-width: 768px) {
  .users-table {
    overflow-x: auto;
  }
  
  .table-header,
  .table-row {
    min-width: 1000rpx;
  }
  
  .search-box {
    flex-direction: column;
  }
  
  .filter-box {
    flex-direction: column;
  }
  
  .batch-actions {
    flex-wrap: wrap;
  }
  
  .action-col {
    flex-wrap: wrap;
  }
}