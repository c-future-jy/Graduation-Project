<!-- pages/admin/index.wxml -->
<view class="admin-container">
  <!-- 顶部导航栏 -->
  <view class="admin-header">
    <view class="header-left">
      <text class="logo">校园服务管理后台</text>
    </view>
    <view class="header-right">
      <view class="user-info">
        <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view class="user-details">
          <text class="user-name">{{userInfo.nickName}}</text>
          <text class="user-role">管理员</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="admin-content">
    <!-- 左侧菜单 -->
    <view class="admin-sidebar">
      <!-- 顶部LOGO区域 
      <view class="sidebar-header">
        <text class="logo">校园服务管理</text>
      </view>-->
      
      <!-- 中间菜单区域 -->
      <view wx:for="{{menuSections}}" wx:key="title" class="menu-section">
        <view class="section-title">{{item.title}}</view>
        <view 
          wx:for="{{item.items}}" 
          wx:key="id"
          class="menu-item {{activeTab === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          data-url="{{item.url}}"
          data-title="{{item.name}}"
          bindtap="switchMenu"
        >
          <text class="menu-name">{{item.name}}</text>
          <view wx:if="{{badgeMap[item.id]}}" class="menu-badge">{{badgeMap[item.id]}}</view>
        </view>
      </view>
      
      <!-- 底部区域 -->
      <view class="sidebar-footer">
        <view class="footer-button" bindtap="logout">
          <text class="menu-name">退出登录</text>
        </view>
      </view>
    </view>

    <!-- 右侧内容区 -->
    <view class="admin-main">
      <view class="welcome-section">
        <text class="welcome-title">👋 欢迎回来，{{userInfo.nickName}}！</text>
        <text class="welcome-datetime">{{today}}</text>
        <text class="welcome-datetime">{{weekday}} {{currentTime}}</text>
        <text class="welcome-blessing">祝您工作顺利！</text>
      </view>
      <view class="dashboard-preview">
        <text class="preview-title">管理概览</text>
        <view class="preview-cards">
          <view class="preview-card" bindtap="goToPage" data-url="/pages/admin/users/users" data-title="用户管理">
            <text class="card-icon">👥</text>
            <text class="card-title">用户管理</text>
            <text class="card-desc">管理平台用户账号</text>
          </view>
          <view class="preview-card" bindtap="goToPage" data-url="/pages/admin/merchants/merchants" data-title="商家管理">
            <text class="card-icon">🏪</text>
            <text class="card-title">商家管理</text>
            <text class="card-desc">审核和管理商家</text>
          </view>
          <view class="preview-card" bindtap="goToPage" data-url="/pages/admin/products/products" data-title="商品管理">
            <text class="card-icon">📦</text>
            <text class="card-title">商品管理</text>
            <text class="card-desc">管理平台商品</text>
          </view>
          <view class="preview-card" bindtap="goToPage" data-url="/pages/admin/orders/orders" data-title="订单管理">
            <text class="card-icon">📋</text>
            <text class="card-title">订单管理</text>
            <text class="card-desc">处理平台订单</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>