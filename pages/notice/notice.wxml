<!--pages/notice/notice.wxml-->
<view class="notice-container">
 
  <!-- 通知列表 -->
  <view class="notice-list">
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>
    
    <view wx:else>
      <view wx:if="{{notifications.length === 0}}" class="empty">
        <image src="/assets/images/kong.jpg" mode="aspectFit" class="empty-icon" />
        <text class="empty-text">暂无通知</text>
      </view>
      
      <view wx:else>
          <view wx:for="{{notifications}}" wx:for-index="idx" wx:key="id" class="notice-item" bindtap="viewNotification" data-id="{{item.id}}" data-index="{{idx}}">
          <view class="notice-header">
              <view class="notice-title-wrap">
                <text wx:if="{{!item.is_read}}" class="unread-dot"></text>
                <text class="notice-title">{{item.title}}</text>
              </view>
              <text class="notice-time">{{item.displayTime}}</text>
          </view>
          <text class="notice-content">{{item.content}}</text>
        </view>
      </view>
    </view>
  </view>
</view>