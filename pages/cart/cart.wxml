
<!-- 购物车页面 -->
<view class="cart-container" catchtap="preventTap">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error-container">
    <image src="/images/error.png" class="error-image" />
    <text class="error-text">网络错误，请重试</text>
    <button class="retry-button" bindtap="loadCartData">重新加载</button>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!hasGoods}}" class="empty-container">
    <image src="/images/kong.jpg" class="empty-image" />
    <text class="empty-text">购物车空空如也</text>
    <button class="go-shopping-button" bindtap="goShopping">去逛逛</button>
  </view>

  <!-- 购物车商品列表 -->
  <view wx:else class="cart-list">
    <!-- 商家分组 -->
    <view wx:for="{{merchants}}" wx:key="{{item.merchantId}}" class="merchant-group" catchtap="preventTap">
      <!-- 商家头部 -->
      <view class="merchant-header" catchtap="preventTap">
        <view class="merchant-info" catchtap="preventTap">
          <image wx:if="{{item.merchantLogo}}" src="{{item.merchantLogo}}" class="merchant-logo" />
          <text class="merchant-name">{{item.merchantName}}</text>
        </view>
        <checkbox class="merchant-checkbox" checked="{{item.checked}}" bindchange="toggleMerchantCheck" data-merchant-id="{{item.merchantId}}" />
      </view>

      <!-- 商品列表 -->
      <view class="goods-list" catchtap="preventTap">
        <view wx:for="{{item.goods}}" wx:key="{{item.goodsId}}" class="goods-item" data-goods-id="{{item.goodsId}}" data-merchant-id="{{item.merchantId}}" catchtap="preventTap">
          <!-- 商品选中状态 -->
          <checkbox class="goods-checkbox" checked="{{item.checked}}" bindchange="toggleGoodsCheck" data-goods-id="{{item.goodsId}}" data-merchant-id="{{item.merchantId}}" />

          <!-- 商品图片 -->
          <image src="{{item.goodsImage}}" class="goods-image" />

          <!-- 商品信息 -->
          <view class="goods-info" catchtap="preventTap">
            <!-- 商品名称 -->
            <text class="goods-name">{{item.goodsName}}</text>

            <!-- 商品规格 -->
            <text class="goods-spec">{{item.spec}}</text>

            <!-- 价格和数量 -->
            <view class="goods-bottom" catchtap="preventTap">
              <text class="goods-price">¥{{item.price}}</text>
              
              <!-- 数量调整 -->
              <view class="quantity-control" catchtap="preventTap">
                <button class="quantity-btn minus" bindtap="decreaseQuantity" data-goods-id="{{item.goodsId}}" data-merchant-id="{{item.merchantId}}" disabled="{{item.quantity <= 1 || item.stock === 0}}">
                  -
                </button>
                <input class="quantity-input" type="number" value="{{item.quantity}}" bindinput="changeQuantity" data-goods-id="{{item.goodsId}}" data-merchant-id="{{item.merchantId}}" />
                <button class="quantity-btn plus" bindtap="increaseQuantity" data-goods-id="{{item.goodsId}}" data-merchant-id="{{item.merchantId}}" disabled="{{item.quantity >= item.stock || item.stock === 0}}">
                  +
                </button>
              </view>
            </view>
          </view>

          <!-- 库存状态 -->
          <view wx:if="{{item.stock === 0}}" class="stock-status out-of-stock">库存不足</view>
          <view wx:elif="{{item.stock < 10}}" class="stock-status low-stock">仅剩{{item.stock}}件</view>

          <!-- 左滑删除按钮 -->
          <view class="delete-btn" bindtap="deleteGoods" data-goods-id="{{item.goodsId}}" data-merchant-id="{{item.merchantId}}">
            删除
          </view>
        </view>
      </view>
    </view>

    <!-- 失效商品 -->
    <view wx:if="{{invalidGoods.length > 0}}" class="invalid-section" catchtap="preventTap">
      <view class="invalid-header" catchtap="preventTap">
        <text class="invalid-title">失效商品</text>
        <text class="clean-btn" bindtap="cleanInvalidGoods">一键清理</text>
      </view>
      <view class="invalid-list" catchtap="preventTap">
        <view wx:for="{{invalidGoods}}" wx:key="{{item.goodsId}}" class="invalid-item" catchtap="preventTap">
          <image src="{{item.goodsImage}}" class="invalid-image" />
          <view class="invalid-info" catchtap="preventTap">
            <text class="invalid-name">{{item.goodsName}}</text>
            <text class="invalid-reason">{{item.reason}}</text>
          </view>
          <button class="invalid-delete-btn" bindtap="deleteInvalidGoods" data-goods-id="{{item.goodsId}}">删除</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 结算栏 -->
  <view wx:if="{{hasGoods}}" class="checkout-bar" catchtap="preventTap">
    <view class="checkout-left" catchtap="preventTap">
      <checkbox class="checkout-checkbox" checked="{{allChecked}}" bindchange="toggleAllCheck" />
      <text class="checkout-text">全选</text>
    </view>
    <view class="checkout-right" catchtap="preventTap">
      <view class="total-price" catchtap="preventTap">
        <text class="total-label">合计：</text>
        <text class="total-value">¥{{totalPrice}}</text>
      </view>
      <button class="checkout-button" bindtap="goCheckout" disabled="{{!hasCheckedGoods}}">
        结算({{checkedCount}})
      </button>
    </view>
  </view>

  <!-- 编辑模式 -->
  <view wx:if="{{editMode}}" class="edit-bar" catchtap="preventTap">
    <view class="edit-left" catchtap="preventTap">
      <checkbox class="edit-checkbox" checked="{{allChecked}}" bindchange="toggleAllCheck" />
      <text class="edit-text">全选</text>
    </view>
    <view class="edit-right" catchtap="preventTap">
      <button class="delete-all-button" bindtap="deleteSelectedGoods" disabled="{{!hasCheckedGoods}}">
        删除选中({{checkedCount}})
      </button>
      <button class="exit-edit-button" bindtap="exitEditMode">完成</button>
    </view>
  </view>
</view>