
<!-- 购物车页面 -->
<view class="cart-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error-container">
    <image src="/assets/images/chatu-2.jpg" class="error-image" />
    <text class="error-text">网络错误，请重试</text>
    <button class="retry-button" bindtap="loadCartData">重新加载</button>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!hasGoods}}" class="empty-container">
    <image src="/assets/images/kong.jpg" class="empty-image" />
    <text class="empty-text">购物车空空如也</text>
    <button class="go-shopping-button" bindtap="goShopping">去逛逛</button>
  </view>

  <!-- 购物车商品列表 -->
  <view wx:else class="cart-list">
    <!-- 商家分组 -->
    <view wx:for="{{merchants}}" wx:key="merchantId" wx:for-item="merchant" class="merchant-group">
      <!-- 商家头部 -->
      <view class="merchant-header">
        <view class="merchant-info">
          <image
            src="{{merchant.merchantLogo || defaultMerchantLogo}}"
            class="merchant-logo"
            mode="aspectFill"
            binderror="onMerchantLogoError"
            data-merchant-id="{{merchant.merchantId}}"
          />
          <text class="merchant-name">{{merchant.merchantName}}</text>
        </view>
        <checkbox
          class="merchant-checkbox"
          checked="{{merchant.checked}}"
          bindchange="toggleMerchantCheck"
          data-merchant-id="{{merchant.merchantId}}"
        />
      </view>

      <!-- 商品列表 -->
      <view class="goods-list">
        <view
          wx:for="{{merchant.goods}}"
          wx:key="cartId"
          wx:for-item="goods"
          class="goods-item"
          bindtap="goGoodsDetail"
          data-goods-id="{{goods.goodsId}}"
        >
          <!-- 商品选中状态（阻止跳转） -->
          <checkbox
            class="goods-checkbox"
            checked="{{goods.checked}}"
            catchtap="preventTap"
            bindchange="toggleGoodsCheck"
            data-cart-id="{{goods.cartId}}"
            data-goods-id="{{goods.goodsId}}"
            data-merchant-id="{{merchant.merchantId}}"
          />

          <!-- 商品图片 -->
          <image
            src="{{goods.goodsImage || defaultGoodsImage}}"
            class="goods-image"
            mode="aspectFill"
            binderror="onGoodsImageError"
            data-cart-id="{{goods.cartId}}"
          />

          <!-- 商品信息 -->
          <view class="goods-info">
            <!-- 商品名称 -->
            <text class="goods-name">{{goods.goodsName}}</text>

            <!-- 商品规格 -->
            <text class="goods-spec">{{goods.spec}}</text>

            <!-- 价格和数量 -->
            <view class="goods-bottom">
              <text class="goods-price">¥{{goods.price}}</text>
              
              <!-- 数量调整 -->
              <view class="quantity-control" catchtap="preventTap">
                <button class="quantity-btn minus" catchtap="decreaseQuantity" data-cart-id="{{goods.cartId}}" data-merchant-id="{{merchant.merchantId}}">
                  -
                </button>
                <input class="quantity-input" type="number" value="{{goods.quantity}}" maxlength="2" bindblur="changeQuantity" data-cart-id="{{goods.cartId}}" data-merchant-id="{{merchant.merchantId}}" />
                <button class="quantity-btn plus" catchtap="increaseQuantity" data-cart-id="{{goods.cartId}}" data-merchant-id="{{merchant.merchantId}}" disabled="{{goods.quantity >= goods.stock || goods.stock === 0}}">
                  +
                </button>
              </view>
            </view>
          </view>

          <!-- 库存状态 -->
          <view wx:if="{{goods.stock === 0}}" class="stock-status out-of-stock">库存不足</view>
          <view wx:elif="{{goods.stock < 10}}" class="stock-status low-stock">仅剩{{goods.stock}}件</view>
        </view>
      </view>
    </view>

    <!-- 失效商品 -->
    <view wx:if="{{invalidGoods.length > 0}}" class="invalid-section">
      <view class="invalid-header">
        <text class="invalid-title">失效商品</text>
        <text class="clean-btn" bindtap="cleanInvalidGoods">一键清理</text>
      </view>
      <view class="invalid-list">
        <view wx:for="{{invalidGoods}}" wx:key="cartId" wx:for-item="goods" class="invalid-item">
          <image src="{{goods.goodsImage || defaultGoodsImage}}" class="invalid-image" mode="aspectFill" binderror="onInvalidGoodsImageError" data-cart-id="{{goods.cartId}}" />
          <view class="invalid-info">
            <text class="invalid-name">{{goods.goodsName}}</text>
            <text class="invalid-reason">{{goods.reason}}</text>
          </view>
          <button class="invalid-delete-btn" bindtap="deleteInvalidGoods" data-cart-id="{{goods.cartId}}">删除</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 结算栏 -->
  <view wx:if="{{hasGoods}}" class="checkout-bar">
    <view class="checkout-left">
      <checkbox class="checkout-checkbox" checked="{{allChecked}}" bindchange="toggleAllCheck" />
      <text class="checkout-text">全选</text>
    </view>
    <view class="checkout-right">
      <view class="total-price">
        <text class="total-label">合计：</text>
        <text class="total-value">¥{{totalPrice}}</text>
      </view>
      <button class="checkout-button" bindtap="goCheckout" disabled="{{!hasCheckedGoods}}">
        结算({{checkedCount}})
      </button>
    </view>
  </view>

</view>