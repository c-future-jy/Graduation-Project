<!--pages/detail/detail.wxml-->
<view class="container">
  <!-- 商品图片 -->
  <view class="product-image">
    <image src="{{product.image || '/assets/images/kong.jpg'}}" mode="aspectFill" />
  </view>

  <!-- 商品信息 -->
  <view class="product-info">
    <view class="price-section">
      <text class="price">¥{{product.price}}</text>
      <text class="stock">库存: {{product.stock}}</text>
    </view>

    <view class="name">{{product.name}}</view>

    <view class="category" wx:if="{{product.category_name}}">
      <text>分类: {{product.category_name}}</text>
    </view>

    <view class="description" wx:if="{{product.description}}">
      <view class="section-title">商品描述</view>
      <text>{{product.description}}</text>
    </view>
  </view>

  <!-- 商家信息 -->
  <view class="merchant-info" wx:if="{{merchant}}">
    <view class="section-title">店铺信息</view>
    <view class="merchant-item">
      <text class="merchant-name">{{merchant.name}}</text>
      <text class="merchant-status {{merchant.status === 1 ? 'open' : 'closed'}}">
        {{merchant.status === 1 ? '营业中' : '休息中'}}
      </text>
    </view>
    <view class="merchant-address">{{merchant.address}}</view>
    <view class="merchant-phone">{{merchant.phone}}</view>
  </view>

  <!-- 用户评价（可选） -->
  <view class="reviews-section">
    <view class="section-title">用户评价</view>
    <view class="no-reviews" wx:if="{{!reviews || reviews.length === 0}}">
      <text>暂无评价</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <!-- 联系商家/客服模块：按需求暂时移除（不展示、不触发） -->
    <!--
    <view class="contact-btn" bindtap="contactMerchant">
      <text>联系客服</text>
    </view>
    -->
    <view class="cart-btn" bindtap="addToCart">
      <text>加入购物车</text>
    </view>
    <view class="buy-btn" bindtap="buyNow">
      <text>立即购买</text>
    </view>
  </view>
</view>