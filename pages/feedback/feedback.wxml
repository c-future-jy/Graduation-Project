<!--pages/feedback/feedback.wxml-->
<view class="feedback-page">
  <view class="feedback-header">
    <text class="feedback-title">商品评价</text>
  </view>
  
  <!-- 评分组件 -->
  <view class="rating-section">
    <text class="rating-label">商品评分</text>
    <view class="rating-stars">
      <image 
        wx:for="[1,2,3,4,5]" 
        wx:key="{{index}}"
        class="star {{rating >= index + 1 ? 'active' : ''}}"
        src="{{rating >= index + 1 ? '../../../assets/star-active.png' : '../../../assets/star-inactive.png'}}"
        bindtap="setRating"
        data-rating="{{index + 1}}"
      ></image>
    </view>
  </view>
  
  <!-- 评价内容 -->
  <view class="content-section">
    <text class="content-label">评价内容</text>
    <textarea 
      class="content-input" 
      placeholder="请输入您的评价..." 
      value="{{content}}"
      bindinput="onContentInput"
      maxlength="500"
    ></textarea>
    <text class="content-count">{{content.length}}/500</text>
  </view>
  
  <!-- 图片上传 -->
  <view class="image-section">
    <text class="image-label">上传图片</text>
    <view class="image-uploader">
      <view 
        class="upload-btn" 
        wx:if="{{images.length < 5}}"
        bindtap="chooseImage"
      >
        <text class="upload-icon">+</text>
      </view>
      <view 
        class="image-item" 
        wx:for="{{images}}" 
        wx:key="{{index}}"
      >
        <image 
          class="uploaded-image" 
          src="{{item}}" 
          mode="aspectFill"
          bindtap="previewImage"
          data-index="{{index}}"
        ></image>
        <view 
          class="image-delete" 
          bindtap="deleteImage"
          data-index="{{index}}"
        >
          <text>×</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 提交按钮 -->
  <view class="submit-section">
    <button 
      class="submit-btn" 
      bindtap="submitFeedback"
      loading="{{loading}}"
      disabled="{{loading || !rating || !content}}">
      提交评价
    </button>
  </view>
</view>