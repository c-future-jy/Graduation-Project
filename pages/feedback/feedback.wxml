<!--pages/feedback/feedback.wxml-->
<view class="feedback-page">
  
  
  <!-- 反馈类型选择 -->
  <view class="type-section">
    <text class="type-label">反馈类型<text class="required">*</text></text>
    <view class="type-options">
      <view 
        class="type-option {{feedbackType === 1 ? 'active' : ''}}"
        bindtap="selectFeedbackType"
        data-type="1"
      >
        <text>订单评价</text>
      </view>
      <view 
        class="type-option {{feedbackType === 2 ? 'active' : ''}}"
        bindtap="selectFeedbackType"
        data-type="2"
      >
        <text>商家评价</text>
      </view>
      <view 
        class="type-option {{feedbackType === 3 ? 'active' : ''}}"
        bindtap="selectFeedbackType"
        data-type="3"
      >
        <text>平台反馈</text>
      </view>
    </view>
  </view>
  
  <!-- 订单选择（订单评价时显示） -->
  <view class="order-section" wx:if="{{feedbackType === 1}}">
    <text class="order-label">选择订单<text class="required">*</text></text>
    <picker bindchange="bindOrderChange" value="{{orderIndex >= 0 ? orderIndex : 0}}" range="{{orders}}" range-key="orderNo" class="order-picker">
      <view class="picker-view">
        <text class="picker-text">{{orderIndex >= 0 && orders[orderIndex] ? orders[orderIndex].orderNo : (orders.length > 0 ? '请选择订单' : '暂无可用订单')}}</text>
      </view>
    </picker>
  </view>
  
  <!-- 商家选择（商家评价时显示） -->
  <view class="merchant-section" wx:if="{{feedbackType === 2}}">
    <text class="merchant-label">选择商家<text class="required">*</text></text>
    <picker bindchange="bindMerchantChange" value="{{merchantIndex >= 0 ? merchantIndex : 0}}" range="{{merchants}}" range-key="name" class="merchant-picker">
      <view class="picker-view">
        <text class="picker-text">{{merchantIndex >= 0 && merchants[merchantIndex] ? merchants[merchantIndex].name : (merchants.length > 0 ? '请选择商家' : '暂无可用商家')}}</text>
      </view>
    </picker>
  </view>
  
  <!-- 评分组件（平台反馈可选；订单/商家评价必填） -->
  <view class="rating-section">
    <text class="rating-label">
      {{feedbackType === 3 ? '评分（可选）' : '评分'}}
      <text wx:if="{{feedbackType !== 3}}" class="required">*</text>
    </text>
    <view class="rating-input">
      <input 
        type="number" 
        class="rating-input-field" 
        placeholder="{{feedbackType === 3 ? '请输入1-5分（可选）' : '请输入1-5分'}}"
        value="{{rating}}"
        bindinput="onRatingInput"
        min="1"
        max="5"
        step="1"
      ></input>
      <text class="rating-hint">1-5分</text>
    </view>
  </view>
  
  <!-- 评价内容 -->
  <view class="content-section">
    <text class="content-label">反馈内容<text class="required">*</text></text>
    <textarea 
      class="content-input" 
      placeholder="请描述您的反馈内容..." 
      value="{{content}}"
      bindinput="onContentInput"
      maxlength="500"
    ></textarea>
    <text class="content-count">{{content.length}}/500</text>
  </view>
  
  <!-- 图片上传 -->
  <view class="image-section">
    <text class="image-label">上传图片（可选）</text>
    <view class="image-uploader">
      <view 
        class="upload-btn" 
        wx:if="{{images.length < 4}}"
        bindtap="chooseImage"
      >
        <text class="upload-icon">+</text>
      </view>
      <view 
        class="image-item" 
        wx:for="{{images}}" 
        wx:key="{{index}}"
      >
        <image 
          class="uploaded-image" 
          src="{{item}}" 
          mode="aspectFill"
          bindtap="previewImage"
          data-index="{{index}}"
        ></image>
        <view 
          class="image-delete" 
          bindtap="deleteImage"
          data-index="{{index}}"
        >
          <text>×</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 提交按钮 -->
  <view class="submit-section">
    <button 
      class="submit-btn" 
      bindtap="submitFeedback"
      loading="{{loading}}"
      disabled="{{loading}}">
      提交反馈
    </button>
  </view>
</view>