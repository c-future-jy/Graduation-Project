/* pages/profile/profile.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 用户信息卡片 */
.user-card {
  background-color: #fff;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-detail {
  flex: 1;
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.nickname {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-right: 12rpx;
}

.role-tag {
  font-size: 12px;
  color: #fff;
  background-color: #4CAF50;
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
  margin-right: 8rpx;
}

.role-tag.merchant {
  background-color: #2196F3;
}

.role-tag.admin {
  background-color: #FF9800;
}

.desc {
  font-size: 12px;
  color: #999;
  margin-bottom: 4rpx;
}

.phone {
  font-size: 12px;
  color: #666;
}

.arrow {
  font-size: 16px;
  color: #999;
}

/* 订单快捷入口 */
.order-section {
  background-color: #fff;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.more {
  font-size: 14px;
  color: #999;
}

.order-menu {
  display: flex;
  justify-content: space-around;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.order-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.order-text {
  font-size: 12px;
  color: #666;
}

.badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background-color: #FF6B35;
  color: #fff;
  font-size: 10px;
  padding: 2rpx 6rpx;
  border-radius: 10rpx;
  min-width: 20rpx;
  text-align: center;
}

/* 常用功能列表 */
.menu-section {
  background-color: #fff;
  margin-bottom: 12rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-left {
  display: flex;
  align-items: center;
  position: relative;
}

.menu-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 12rpx;
}

.menu-text {
  font-size: 14px;
  color: #333;
}

.red-dot {
  position: absolute;
  top: 0;
  right: -10rpx;
  background-color: #FF6B35;
  color: #fff;
  font-size: 10px;
  padding: 2rpx 6rpx;
  border-radius: 10rpx;
  min-width: 20rpx;
  text-align: center;
}

/* 退出登录按钮 */
.logout-section {
  padding: 32rpx 16rpx;
}

.logout-btn {
  width: 100%;
  height: 48px;
  line-height: 48px;
  background-color: #fff;
  color: #FF6B35;
  font-size: 16px;
  border-radius: 8rpx;
  border: 1rpx solid #FF6B35;
}
