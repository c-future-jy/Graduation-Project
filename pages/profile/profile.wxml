<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card" bindtap="goToLogin" wx:if="{{!isLogin}}">
    <view class="user-info">
      <image class="avatar" src="/assets/images/morentouxiang.jpg" mode="aspectFill" />
      <view class="user-detail">
        <text class="nickname">点击登录</text>
        <text class="desc">登录享受更多服务</text>  
      </view>
    </view>
    <text class="arrow"></text>
  </view>
  <view class="user-card" wx:else bindtap="goToEditProfile">
    <!-- 已登录状态显示的内容 -->
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
      <view class="user-detail">
        <view class="user-header">
          <text class="nickname">{{userInfo.nickName}}</text>
          <view class="role-tag" wx:if="{{userInfo.role === 1}}">学生</view>
          <view class="role-tag merchant" wx:elif="{{userInfo.role === 2}}">商家</view>
          <view class="role-tag admin" wx:elif="{{userInfo.role === 3}}">管理员</view>
        </view>
        <text class="desc">校园生活，一站搞定</text>
        <text class="phone" wx:if="{{userInfo.phone}}">手机号：{{userInfo.phone}}</text>
      </view>
    </view>
    <text class="arrow">></text>
  </view>
  
  <!-- 管理员后台入口 -->
  <view class="menu-section" wx:if="{{isLogin && userInfo.role === 3}}">
    <view class="menu-item" bindtap="goToAdmin">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/images/sub_account.jpg" mode="aspectFit"></image>
        <text class="menu-text">管理后台</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 商家后台入口 -->
  <view class="menu-section" wx:if="{{isLogin && userInfo.role === 2}}">
    <view class="menu-item" bindtap="goToMerchantCenter">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/images/gongnengcaidan.jpg" mode="aspectFit"></image>
        <text class="menu-text">商家后台</text>
        <view class="red-dot" wx:if="{{merchantPendingOrders > 0}}">{{merchantPendingOrders > 99 ? '99+' : merchantPendingOrders}}</view>
      </view>
      <text class="arrow">></text>
    </view>
  </view>
  
  <!-- 订单快捷入口 -->
  <view class="order-section">
    <!-- 标题行 -->
    <view class="section-title">
      <text class="title">我的订单</text>
      <text class="more" bindtap="navigateToOrders" data-status="all">查看全部></text>
    </view>
    <!-- 订单状态菜单 -->
    <view class="order-menu">
      <!-- 全部订单 -->
      <view class="order-item" bindtap="goToOrderStatus" data-status="all">
        <image class="order-icon" src="/assets/images/quanbu.jpg" mode="aspectFit"/>
        <text class="order-text">全部</text>
      </view>
      <!-- 待支付 -->
      <view class="order-item" bindtap="goToOrderStatus" data-status="0">
        <image class="order-icon" src="/assets/images/zhifu-1.jpg" mode="aspectFit"/>
        <text class="order-text">待支付</text>
        <view class="badge" wx:if="{{pendingPayCount > 0}}">{{pendingPayCount}}</view>
      </view>
      <!-- 待发货 -->
      <view class="order-item" bindtap="goToOrderStatus" data-status="1">
        <image class="order-icon" src="/assets/images/daifahuo-1.jpg" mode="aspectFit"/>
        <text class="order-text">待发货</text>
        <view class="badge" wx:if="{{pendingDeliverCount >0}}">{{pendingDeliverCount}}</view>
      </view>
      <!-- 已完成 -->
      <view class="order-item" bindtap="goToOrderStatus" data-status="3">
        <image class="order-icon" src="/assets/images/wancheng-1.jpg" mode="aspectFit"/>
        <text class="order-text">已完成</text>
      </view>
    </view>
  </view>
  
  <!-- 常用功能列表 -->
  <view class="menu-section">
    <!-- 个人信息 -->
    <view class="menu-item" bindtap="goToEditProfile" wx:if="{{isLogin}}">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/images/user.jpg" mode="aspectFit"></image>
        <text class="menu-text">个人信息</text>
      </view>
      <text class="arrow">></text>
    </view>

    <!-- 收货地址 -->
    <view class="menu-item" bindtap="goToAddress">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/images/region.jpg" mode="aspectFit"></image>
        <text class="menu-text">收货地址</text>
      </view>
      <text class="arrow">></text>
    </view>

    <!-- 申请成为商家 -->
    <view class="menu-item" bindtap="applyMerchant" wx:if="{{isLogin && userInfo.role === 1}}">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/images/chengweiwomen.jpg" mode="aspectFit"></image>
        <text class="menu-text">成为商家</text>
      </view>
      <text class="arrow">></text>
    </view>
    
    <!-- 消息通知 -->
    <view class="menu-item" bindtap="goToNotice">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/images/message.jpg" mode="aspectFit"></image>
        <text class="menu-text">消息通知</text>
        <view class="red-dot" wx:if="{{unreadNoticeCount > 0}}">{{unreadNoticeCount}}</view>
      </view>
      <text class="arrow">></text>
    </view>

    <!-- 意见反馈 -->
    <view class="menu-item" bindtap="goToFeedback">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/images/edit.jpg" mode="aspectFit"></image>
        <text class="menu-text">意见反馈</text>
      </view>
      <text class="arrow">></text>
    </view>

    <!-- 关于我们 -->
    <view class="menu-item" bindtap="goToAbout">
      <view class="menu-left">
        <image class="menu-icon" src="/assets/images/sub_account.jpg" mode="aspectFit"></image>
        <text class="menu-text">关于我们</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>
  
  <!-- 退出登录按钮 -->
  <view class="logout-section" wx:if="{{isLogin}}">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>