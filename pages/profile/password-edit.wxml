<!--pages/profile/password-edit.wxml-->
<view class="container">
  <!-- 密码修改表单 -->
  <view class="form-container">
    <!-- 旧密码 -->
    <view class="form-item">
      <view class="form-label">旧密码</view>
      <input 
        class="form-input" 
        placeholder="请输入旧密码" 
        value="{{oldPassword}}" 
        bindinput="onOldPasswordChange"
        password
        maxlength="18"
      />
      <text wx:if="{{oldPasswordError}}" class="error-tip">{{oldPasswordError}}</text>
    </view>

    <!-- 新密码 -->
    <view class="form-item">
      <view class="form-label">新密码</view>
      <input 
        class="form-input" 
        placeholder="请设置新密码（6-18位，包含字母和数字）" 
        value="{{newPassword}}" 
        bindinput="onNewPasswordChange"
        password
        maxlength="18"
      />
      <text wx:if="{{newPasswordError}}" class="error-tip">{{newPasswordError}}</text>
    </view>

    <!-- 确认新密码 -->
    <view class="form-item">
      <view class="form-label">确认新密码</view>
      <input 
        class="form-input" 
        placeholder="请确认新密码" 
        value="{{confirmPassword}}" 
        bindinput="onConfirmPasswordChange"
        password
        maxlength="18"
      />
      <text wx:if="{{confirmPasswordError}}" class="error-tip">{{confirmPasswordError}}</text>
    </view>

    <!-- 保存按钮 -->
    <view class="save-section">
      <button class="save-btn" bindtap="savePassword">保存修改</button>
    </view>
  </view>
</view>