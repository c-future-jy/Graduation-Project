<!--pages/profile/edit-profile.wxml-->
<view class="container">
  <!-- 个人信息表单 -->
  <view class="form-container">
    <!-- 基础信息模块 -->
    <view class="form-section">
      <view class="section-title">基础信息</view>
      
      <!-- 头像 -->
      <view class="form-item">
        <view class="form-label">头像</view>
        <view class="form-value avatar-area" bindtap="chooseAvatar">
          <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
          <view class="avatar-meta">
            <text class="upload-text">更换头像</text>
            <text class="avatar-tip">支持JPG/PNG，不超过2MB</text>
            <button wx:if="{{lastUploadError}}" class="retry-btn" catchtap="retryUpload">上传失败，点此重试</button>
          </view>
          <text wx:if="{{uploadingAvatar}}" class="uploading-tip">上传中...</text>
        </view>
          <!-- 隐藏 canvas，用于图片压缩导出 -->
          <canvas canvas-id="avatarCanvas" class="hidden-canvas"></canvas>
      </view>

      <!-- 昵称 -->
      <view class="form-item">
        <view class="form-label">昵称</view>
        <input 
          class="form-input" 
          placeholder="请输入昵称" 
          placeholder-style="color:#bfbfbf;font-size:14px;"
          value="{{userInfo.nickName}}" 
          bindinput="onNickNameChange"
          bindfocus="onInputFocus"
          bindblur="onInputBlur"
          data-field="nickName"
        />
        <text wx:if="{{nickNameError}}" class="error-tip">{{nickNameError}}</text>
      </view>

      <!-- 手机号 -->
      <view class="form-item">
        <view class="form-label">手机号</view>
        <input 
          class="form-input" 
          placeholder="请输入手机号" 
          placeholder-style="color:#bfbfbf;font-size:14px;"
          value="{{userInfo.phone}}" 
          bindinput="onPhoneChange"
          type="number"
          maxlength="11"
          bindfocus="onInputFocus"
          bindblur="onInputBlur"
          data-field="phone"
        />
        <text wx:if="{{phoneError}}" class="error-tip">{{phoneError}}</text>
      </view>

      <!-- 保存基础信息按钮 -->
      <view class="section-save">
        <button class="save-btn" bindtap="saveBasicInfo" disabled="{{saving}}">{{saving? '保存中...' : '保存基础信息'}}</button>
      </view>
    </view>

    <!-- 密码修改模块 -->
    <view class="form-section">
      <view class="section-title">
        <text>密码修改</text>
        <button class="password-btn" bindtap="goToPasswordEdit">修改密码</button>
      </view>
    </view>

    <!-- 用户角色 -->
    <view class="form-item readonly-item">
      <view class="form-label">用户角色</view>
      <view class="form-value">
        <text class="role-text readonly-text">{{roleText}}</text>
      </view>
    </view>
  </view>
</view>