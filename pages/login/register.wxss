/* pages/login/register.wxss */
.container {
  background-color: transparent;
  min-height: 100vh;
}

/* 注册表单 */
.form-container {
  background-color: #fff;
  margin-top: 12rpx;
  padding: 16rpx;
}

.form-item {
  margin-bottom: 20rpx;
  position: relative;
}

.form-label {
  font-size: 14px;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 14px;
  color: #333;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
}

/* 密码强度 */
.password-strength {
  margin-top: 8rpx;
}

.strength-bar {
  display: flex;
  height: 6rpx;
  margin-bottom: 4rpx;
}

.strength-item {
  flex: 1;
  height: 100%;
  background-color: #e5e5e5;
  margin-right: 8rpx;
  border-radius: 3rpx;
}

.strength-item:last-child {
  margin-right: 0;
}

.strength-item.weak {
  background-color: #ff4757;
}

.strength-item.medium {
  background-color: #ffa502;
}

.strength-item.strong {
  background-color: #2ed573;
}

.strength-text {
  font-size: 12px;
  color: #999;
}

/* 角色选择 */
.role-buttons {
  display: flex;
  margin-top: 8rpx;
}

.role-btn {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  margin: 0 8rpx;
  background-color: #fff;
  transition: all 0.3s;
}

.role-btn.active {
  background-color: #FF6B35;
  border-color: #FF6B35;
}

.role-btn.active .role-text {
  color: #fff;
}

.role-text {
  font-size: 14px;
  color: #333;
}

/* 注册按钮 */
.register-section {
  padding: 32rpx 16rpx;
}

.register-btn {
  width: 100%;
  height: 80rpx;
  background-color: #FF6B35;
  color: #fff;
  border-radius: 8rpx;
  border: none;
  font-size: 16px;
}

.register-btn:disabled {
  background-color: #ffb399;
}

/* 微信登录 */
.wechat-login-section {
  padding: 0 16rpx 32rpx;
}

.line {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.line::before, .line::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background-color: #e5e5e5;
}

.line-text {
  padding: 0 16rpx;
  font-size: 12px;
  color: #999;
}

.wechat-login-btn {
  width: 100%;
  height: 80rpx;
  background-color: #07C160;
  color: #fff;
  border-radius: 8rpx;
  border: none;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.wechat-text {
  font-size: 16px;
  color: #fff;
}
