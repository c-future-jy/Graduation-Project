<!--pages/login/login.wxml-->
<view class="content">
  <view class="head">
    <image src="/assets/images/chatu-1.jpg" mode="aspectFit"/>
  </view>
  
  <view class="form-box">
    <view class="row-input">
      <input placeholder="手机号" maxlength="11" type="number" value="{{phone}}" bindinput="onPhoneChange" />
    </view>
    
    <view class="row-input">
      <input placeholder="密码" password maxlength="18" value="{{password}}" bindinput="onPasswordChange" />
    </view>
    
    <view class="login-btn" bindtap="accountLogin">登录</view>
    
    <view class="menu-link">
      <text bindtap="goToForgotPassword">忘记密码</text>
      <text bindtap="goToRegister">注册账号</text>
    </view>
    
    <view class="line">第三方账号登录</view>
    
    <view class="quick-login">
      <view bindtap="wechatLogin">
        <image src="/assets/images/weixin-1.jpg" mode="aspectFit"/>
      </view>
      
    </view>
  </view>
</view>