/* pages/address/edit-address/edit-address.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.form-section {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #333;
  width: 150rpx;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 10rpx 0;
}

.detail-input {
  min-height: 100rpx;
  line-height: 40rpx;
  padding: 10rpx;
  border: 1rpx solid #f0f0f0;
  border-radius: 8rpx;
}

/* 地区选择器 */
.region-picker {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.region-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

.checkbox-item {
  justify-content: space-between;
}

.checkbox-item checkbox {
  transform: scale(1.5);
}

/* 地区选择器容器 */
.region-picker-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 999;
}

/* 地区选择器 */
.region-picker-view {
  height: 400rpx;
  width: 100%;
}

/* 选择器底部按钮 */
.picker-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  padding: 20rpx;
  font-size: 32rpx;
  border: none;
  background-color: #fff;
}

.cancel-btn {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.confirm-btn {
  color: #ff6b6b;
  font-weight: bold;
}

.picker-item {
  font-size: 28rpx;
  text-align: center;
  height: 80rpx;
  line-height: 80rpx;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 40rpx;
  margin-bottom: 100rpx;
  background-color: #ff6b6b;
  color: #fff;
  font-size: 32rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}
