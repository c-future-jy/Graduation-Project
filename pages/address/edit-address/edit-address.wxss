/* pages/address/edit-address/edit-address.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.form-section {
  height: 400rpx;
  width: 100%;
}

/* 选择器底部按钮 */
.picker-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  padding: 20rpx;
  font-size: 32rpx;
  border: none;
  background-color: #fff;
}

.cancel-btn {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.confirm-btn {
  color: #ff6b6b;
  font-weight: bold;
}

.picker-item {
  font-size: 28rpx;
  text-align: center;
  height: 80rpx;
  line-height: 80rpx;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 40rpx;
  margin-bottom: 100rpx;
  background-color: #ff6b6b;
  color: #fff;
  font-size: 32rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}
