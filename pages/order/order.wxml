<!--pages/order/order.wxml-->
<view class="order-container">
  <!-- Tab切换 -->
  <view class="tab-container">
    <view 
      wx:for="{{tabs}}" 
      wx:key="index"
      class="tab-item {{activeTab === item.status ? 'active' : ''}}"
      bindtap="switchTab"
      data-status="{{item.status}}"
    >
      {{item.name}}
    </view>
  </view>
  
  <!-- 订单列表 -->
  <view class="order-list">
    <view wx:for="{{orders}}" wx:key="orderId" class="order-card" bindtap="goToOrderDetail" data-orderId="{{item.orderId}}">
      <!-- 商家信息 -->
      <view class="merchant-info" bindtap="goToMerchant" data-merchantId="{{item.merchantId}}" data-name="{{item.merchantName}}" catchtap="">
        <image class="merchant-logo" src="{{item.merchantLogo}}" mode="aspectFill"></image>
        <view class="merchant-name">{{item.merchantName}}</view>
        <view class="merchant-arrow">→</view>
      </view>
      
      <!-- 商品列表 -->
      <view class="order-goods">
        <view wx:for="{{item.goodsList}}" wx:key="goodsId" class="goods-item" wx:if="index < 3">
          <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="goods-info">
            <view class="goods-name">{{item.name}}</view>
            <view class="goods-spec">{{item.spec || ''}}</view>
            <view class="goods-price">¥{{item.price}}</view>
          </view>
          <view class="goods-quantity">x{{item.quantity}}</view>
        </view>
        <view wx:if="item.goodsList.length > 3" class="goods-more">
          共{{item.totalQuantity}}件商品
        </view>
      </view>
      
      <!-- 订单底部 -->
      <view class="order-footer">
        <view class="order-price">
          <view class="order-original-price" wx:if="item.originalPrice && item.originalPrice > item.totalPrice">
            ¥{{item.originalPrice}}
          </view>
          <view class="order-actual-price">
            实付：<text class="actual-price">¥{{item.totalPrice}}</text>
          </view>
        </view>
        <view class="order-status status-{{item.status}}">{{item.statusText}}</view>
        <view class="order-actions">
          <button 
            wx:for="{{item.actions}}" 
            wx:key="index"
            class="action-btn {{item.type}}"
            bindtap="handleAction"
            data-orderId="{{item.orderId}}"
            data-action="{{item.action}}"
            catchtap=""
          >
            {{item.text}}
          </button>
        </view>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view wx:if="{{orders.length === 0}}" class="empty-state">
      <image class="empty-image" src="/assets/images/kong.jpg" mode="aspectFit"></image>
      <text class="empty-text">暂无订单</text>
      <button class="empty-button" bindtap="goShopping">去逛逛</button>
    </view>
  </view>
</view>