{
  "name": "campus-service-backend",
  "version": "1.0.0",
  "description": "校园一站式服务平台后端API",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "migrate:status": "node ../sql/migrate.js status",
    "migrate:up": "node ../sql/migrate.js up",
    "migrate:up:safe": "node ../sql/migrate.js up --rollback-on-fail",
    "migrate:up:dry": "node ../sql/migrate.js up --dry-run",
    "migrate:down": "node ../sql/migrate.js down",
    "migrate:down:dry": "node ../sql/migrate.js down --dry-run"
  },
  "keywords": [
    "campus",
    "wechat-miniprogram",
    "nodejs",
    "express"
  ],
  "author": "蔡",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
